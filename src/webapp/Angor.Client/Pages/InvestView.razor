    private async Task StartLightningFlow()
    {
        lightningLoading = true;
        showLightningInvoiceModal = true;
        paymentReceived = false;
        invoiceProcessing = false;
        lightningInvoiceString = null;
        lightningSwapId = null;
        lightningStatusMessage = "Creating Lightning invoice...";
        StateHasChanged();

        try
        {
            var accountInfo = storage.GetAccountInfo(network.Name);
            invoiceAddress = accountInfo.GetNextReceiveAddress();

            if (string.IsNullOrEmpty(invoiceAddress))
            {
                notificationComponent.ShowErrorMessage("Failed to get receive address");
                showLightningInvoiceModal = false;
                lightningLoading = false;
                return;
            }

            var words = await passwordComponent.GetWalletAsync();
            var claimPubKey = _derivationOperations.DeriveInvestorKey(words, project!.ProjectInfo.FounderKey);

            long investmentSats = Investment.InvestmentAmountBtc.ToUnitSatoshi();
            int angorFeePercentage = _networkConfiguration.GetAngorInvestFeePercentage;
            long angorFee = (investmentSats * angorFeePercentage) / 100;

            int stageCount = project!.ProjectInfo.Stages?.Count ?? 1;
            const int txOverhead = 10;
            const int inputSize = 68;
            const int outputSize = 31;
            const int defaultFeeRateSatsPerVbyte = 2;
            int estimatedVSize = txOverhead + inputSize + (stageCount + 2) * outputSize;
            long estimatedMinerFee = estimatedVSize * defaultFeeRateSatsPerVbyte;

            long requiredSats = investmentSats + angorFee + estimatedMinerFee;

            _Logger.LogInformation("Calculating Lightning invoice amount for {RequiredSats} sats on-chain", requiredSats);
            var invoiceAmountResult = await _boltzSwapService.CalculateInvoiceAmountAsync(requiredSats);

            if (invoiceAmountResult.IsFailure)
            {
                _Logger.LogError("Failed to calculate Lightning invoice amount: {Error}", invoiceAmountResult.Error);
                notificationComponent.ShowErrorMessage($"Failed to calculate Lightning fees: {invoiceAmountResult.Error}");
                showLightningInvoiceModal = false;
                lightningLoading = false;
                StateHasChanged();
                return;
            }

            _Logger.LogInformation(
                "Creating Boltz reverse swap: invoice amount={InvoiceAmount} sats, destination={Address}, claimKey={Key}",
                invoiceAmountResult.Value, invoiceAddress, claimPubKey[..8] + "...");

            var swapResult = await _boltzSwapService.CreateSubmarineSwapAsync(
                invoiceAddress, invoiceAmountResult.Value, claimPubKey);

            if (swapResult.IsFailure)
            {
                _Logger.LogError("Failed to create Boltz swap: {Error}", swapResult.Error);
                notificationComponent.ShowErrorMessage($"Failed to create Lightning swap: {swapResult.Error}");
                showLightningInvoiceModal = false;
                lightningLoading = false;
                StateHasChanged();
                return;
            }

            currentSwap = swapResult.Value;
            lightningInvoiceString = currentSwap.Invoice;
            lightningSwapId = currentSwap.Id;
            lightningLoading = false;
            lightningStatusMessage = "Awaiting Lightning payment...";

            _Logger.LogInformation(
                "Boltz swap created: ID={SwapId}, invoice amount={Amount} sats",
                currentSwap.Id, currentSwap.InvoiceAmount);

            StateHasChanged();

            await MonitorLightningSwapAndProceed(accountInfo, requiredSats);
        }
        catch (Exception e)
        {
            _Logger.LogError(e, "Error in Lightning payment flow");
            notificationComponent.ShowErrorMessage($"Lightning error: {e.Message}", e);
            showLightningInvoiceModal = false;
            lightningLoading = false;
        }
        finally
        {
            StateHasChanged();
        }
    }

    private async Task MonitorLightningSwapAndProceed(AccountInfo accountInfo, long requiredSats)
    {
        lightningMonitorCts = new CancellationTokenSource();
        var token = lightningMonitorCts.Token;

        try
        {
            _Logger.LogInformation("Starting Boltz swap monitoring for {SwapId}", lightningSwapId);
            BoltzSwapStatus? lockupStatus = null;
            var maxAttempts = 360;

            for (int i = 0; i < maxAttempts && !token.IsCancellationRequested; i++)
            {
                await Task.Delay(5000, token);

                var statusResult = await _boltzSwapService.GetSwapStatusAsync(lightningSwapId!);
                if (statusResult.IsFailure)
                {
                    _Logger.LogWarning("Failed to poll swap status: {Error}", statusResult.Error);
                    continue;
                }

                var status = statusResult.Value;
                _Logger.LogDebug("Swap {SwapId} status: {Status}", lightningSwapId, status.Status);

                switch (status.Status)
                {
                    case SwapState.InvoicePaid:
                        lightningStatusMessage = "Lightning payment received! Waiting for on-chain lockup...";
                        StateHasChanged();
                        break;

                    case SwapState.TransactionMempool:
                    case SwapState.TransactionConfirmed:
                        _Logger.LogInformation("Swap {SwapId} lockup on-chain: {Status}, txId={TxId}",
                            lightningSwapId, status.Status, status.TransactionId ?? "unknown");
                        lockupStatus = status;
                        break;

                    case SwapState.TransactionClaimed:
                        _Logger.LogInformation("Swap {SwapId} already claimed", lightningSwapId);
                        lockupStatus = status;
                        break;

                    case SwapState.InvoiceFailedToPay:
                    case SwapState.InvoiceExpired:
                    case SwapState.SwapExpired:
                    case SwapState.TransactionRefunded:
                        _Logger.LogWarning("Swap {SwapId} failed: {Status}", lightningSwapId, status.Status);
                        notificationComponent.ShowErrorMessage($"Lightning payment failed: {status.Status}");
                        showLightningInvoiceModal = false;
                        StateHasChanged();
                        return;
                }

                if (lockupStatus != null) break;
            }

            if (lockupStatus == null)
            {
                if (!token.IsCancellationRequested)
                {
                    _Logger.LogWarning("Swap monitoring timed out for {SwapId}", lightningSwapId);
                    notificationComponent.ShowNotificationMessage("Lightning payment timed out. Please try again.", 5);
                }
                showLightningInvoiceModal = false;
                StateHasChanged();
                return;
            }

            paymentReceived = true;
            invoiceProcessing = true;

            if (lockupStatus.Status != SwapState.TransactionClaimed)
            {
                lightningStatusMessage = "Lockup detected! Claiming funds...";
                StateHasChanged();

                var lockupTxHex = lockupStatus.TransactionHex;
                if (string.IsNullOrEmpty(lockupTxHex) && !string.IsNullOrEmpty(lockupStatus.TransactionId))
                {
                    _Logger.LogInformation("Fetching lockup tx hex via indexer for {TxId}", lockupStatus.TransactionId);
                    try
                    {
                        lockupTxHex = await _indexerService.GetTransactionHexByIdAsync(lockupStatus.TransactionId);
                    }
                    catch (Exception ex)
                    {
                        _Logger.LogWarning(ex, "Failed to fetch lockup tx hex from indexer");
                    }
                }

                if (string.IsNullOrEmpty(lockupTxHex))
                {
                    _Logger.LogError("Cannot claim: lockup tx hex unavailable for swap {SwapId}", lightningSwapId);
                    notificationComponent.ShowErrorMessage("Failed to retrieve lockup transaction. Please contact support.");
                    showLightningInvoiceModal = false;
                    StateHasChanged();
                    return;
                }

                var words = await passwordComponent.GetWalletAsync();
                var claimPrivateKey = _derivationOperations.DeriveInvestorPrivateKey(words, project!.ProjectInfo.FounderKey);

                _Logger.LogInformation("Claiming swap {SwapId} from lockup {LockupAddress}",
                    lightningSwapId, currentSwap!.LockupAddress);

                lightningStatusMessage = "Signing and broadcasting claim transaction...";
                StateHasChanged();

                var claimResult = await _boltzClaimService.ClaimSwapAsync(
                    currentSwap, claimPrivateKey, lockupTxHex);

                if (claimResult.IsFailure)
                {
                    _Logger.LogError("Claim failed for swap {SwapId}: {Error}", lightningSwapId, claimResult.Error);
                    notificationComponent.ShowErrorMessage($"Failed to claim funds: {claimResult.Error}");
                    showLightningInvoiceModal = false;
                    StateHasChanged();
                    return;
                }

                _Logger.LogInformation("Claim succeeded for swap {SwapId}: claimTxId={ClaimTxId}",
                    lightningSwapId, claimResult.Value.ClaimTransactionId);
                lightningStatusMessage = "Claim broadcast! Waiting for funds at address...";
                StateHasChanged();
            }
            else
            {
                lightningStatusMessage = "Funds already claimed, detecting deposit...";
                StateHasChanged();
            }

            _Logger.LogInformation("Polling for any funds at {Address}", invoiceAddress);

            List<UtxoData> detectedUtxos = new();
            var pollEnd = DateTime.UtcNow.AddMinutes(10);

            while (DateTime.UtcNow < pollEnd && !token.IsCancellationRequested)
            {
                try
                {
                    var utxos = await _indexerService.FetchUtxoAsync(invoiceAddress!, limit: 50, offset: 0);
                    if (utxos != null && utxos.Any())
                    {
                        detectedUtxos = utxos;
                        _Logger.LogInformation("Detected {Count} UTXO(s) at {Address}, total: {Total} sats",
                            utxos.Count, invoiceAddress, utxos.Sum(u => u.value));
                        break;
                    }
                }
                catch (Exception ex)
                {
                    _Logger.LogWarning(ex, "Error polling address {Address}", invoiceAddress);
                }

                await Task.Delay(5000, token);
            }

            if (detectedUtxos.Count == 0)
            {
                if (!token.IsCancellationRequested)
                {
                    _Logger.LogError("Funds not detected at {Address} after claim for swap {SwapId}", invoiceAddress, lightningSwapId);
                    notificationComponent.ShowErrorMessage("On-chain funds not detected after claim. Please contact support.");
                }
                showLightningInvoiceModal = false;
                StateHasChanged();
                return;
            }

            _Logger.LogInformation("Funds detected for swap {SwapId}, building investment", lightningSwapId);
            lightningStatusMessage = "Building investment transaction...";
            StateHasChanged();

            var addressInfo = accountInfo.AllAddresses().FirstOrDefault(a => a.Address == invoiceAddress);
            if (addressInfo != null)
            {
                foreach (var utxo in detectedUtxos)
                {
                    if (!addressInfo.UtxoData.Any(u => u.outpoint.ToString() == utxo.outpoint.ToString()))
                    {
                        addressInfo.UtxoData.Add(utxo);
                    }
                }
                storage.SetAccountInfo(network.Name, accountInfo);
            }

            await BuildAndSubmitFromAddress(accountInfo);
        }
        catch (OperationCanceledException)
        {
            _Logger.LogInformation("Lightning monitoring cancelled for {SwapId}", lightningSwapId);
        }
        catch (Exception e)
        {
            _Logger.LogError(e, "Error in Lightning swap flow for {SwapId}", lightningSwapId);
            notificationComponent.ShowErrorMessage($"Error: {e.Message}", e);
        }
        finally
        {
            showLightningInvoiceModal = false;
            StateHasChanged();
        }
    }

    private void CloseLightningModal()
    {
        lightningMonitorCts?.Cancel();
        showLightningInvoiceModal = false;
