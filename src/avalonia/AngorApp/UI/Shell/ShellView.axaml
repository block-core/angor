<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:sh="clr-namespace:AngorApp.UI.Shell"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="650"
             x:Class="AngorApp.UI.Shell.ShellView" x:DataType="sh:IShellViewModel"
             Background="{DynamicResource AppBackground}" Container.Name="Shell" Container.Sizing="Width">

    <Design.DataContext>
        <sh:ShellViewModelSample />
    </Design.DataContext>

    <UserControl.Styles>

        <ContainerQuery Name="Shell" Query="min-width:0 and max-width:767">
            <Style Selector="SectionStrip">
                <Setter Property="Orientation" Value="Horizontal" />
                <Setter Property="DockPanel.Dock" Value="Bottom" />
                <Setter Property="MinItemWidth" Value="60" />
            </Style>
            <Style Selector="DockPanel#TopBar">
                <Setter Property="IsVisible" Value="False" />
            </Style>
            
        </ContainerQuery>

        <ContainerQuery Name="Shell" Query="min-width:768">
            <Style Selector="SectionStrip">
                <Setter Property="Orientation" Value="Vertical" />
                <Setter Property="DockPanel.Dock" Value="Left" />
                <Setter Property="Width" Value="200" />
            </Style>
        </ContainerQuery>

        <Style Selector="SectionStrip.Nav SectionStripGroupHeader">
            <Setter Property="Foreground" Value="{DynamicResource Brand}" />
            <Setter Property="FontFamily" Value="Sans Serif" />
            <Setter Property="FontWeight" Value="SemiLight" />
            <Setter Property="FontSize" Value="18" />
            <Setter Property="Margin" Value="10" />
        </Style>

        <Style Selector="SectionStrip.Nav SectionStripItem">
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="IconOptions.Fill" Value="{Binding $self.Foreground}" />
            <Setter Property="Foreground" Value="{DynamicResource TextMuted}" />
            <Setter Property="ClipToBounds" Value="False" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style Selector="SectionStrip.Nav[Orientation=Vertical] SectionStripItem">
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Margin" Value="10" />
            <Setter Property="Padding" Value="10" />
            <Setter Property="IconOptions.Fill" Value="{Binding $self.Foreground}" />
            <Setter Property="Foreground" Value="{DynamicResource TextMuted}" />
            <Setter Property="ClipToBounds" Value="False" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style Selector="SectionStrip.Nav ListBoxItem">
            <Setter Property="ClipToBounds" Value="False" />
        </Style>

        <Style Selector="SectionStrip.Nav SectionStripListBox">
            <Setter Property="ClipToBounds" Value="False" />
        </Style>

        <Style Selector="SectionStrip.Nav">
            <Setter Property="ItemSpacing" Value="10" />
        </Style>

        <Style Selector="SectionStrip.Nav SectionStripItem:pointerover">
            <Setter Property="Background" Value="{DynamicResource SurfaceHover}" />
        </Style>

        <Style Selector="SectionStrip.Nav SectionStripItem:selected">
            <Setter Property="Background" Value="{DynamicResource SurfaceSelected}" />
            <Setter Property="Foreground" Value="{DynamicResource Highlight}" />
        </Style>

        <Style Selector="SectionStrip.Nav SectionStripItem:selected Border">
            <Setter Property="BoxShadow" Value="{DynamicResource SectionShadow}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Stroke}" />
        </Style>
    </UserControl.Styles>

    <DockPanel>
        <DockPanel x:Name="TopBar" DockPanel.Dock="Top" Height="60">
            <PathIcon Height="32" Foreground="{DynamicResource Brand}" Width="200"
                      Data="{StaticResource AngorLogo}" />
            <sh:InfoBar />
        </DockPanel>
        <SectionStrip Classes="Nav" SelectedSection="{Binding SelectedSection}" IconSize="24"
                      Sections="{Binding SidebarSections}" />
        <OverlayBorder Classes="Panel" Padding="0"
                       Background="{DynamicResource TiledLogoBrush}">
            <Frame Content="{Binding SelectedSection.Navigator.Content^}"
                   BackCommand="{Binding SelectedSection.Navigator.Back}">
                <Interaction.Behaviors>
                    <AutoHeaderFooterBehavior />
                </Interaction.Behaviors>
            </Frame>
        </OverlayBorder>
    </DockPanel>

    <!--    <Grid x:Name="TopBar" Margin="0 20 20 20" ColumnDefinitions="Auto *" RowDefinitions="42 *" ColumnSpacing="20" RowSpacing="20">
        <PathIcon Height="32" Foreground="{DynamicResource Brand}" Width="32" Data="{StaticResource AngorLogo}" />
        <DockPanel Grid.Row="0" Grid.Column="1" Dock="Top">
            <DockPanel DockPanel.Dock="Top" HorizontalSpacing="20">
                <TextBlock FontWeight="Bold" VerticalAlignment="Center" FontSize="20" Text="{Binding SelectedSection.FriendlyName}" />
                <Border IsVisible="{Binding ProfileName, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" Background="{DynamicResource Brand}" CornerRadius="4" Padding="8 2" VerticalAlignment="Center">
                    <TextBlock Text="{Binding ProfileName}" FontSize="12" Foreground="White" />
                </Border>
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Right" Spacing="16" Orientation="Horizontal">
                    <StackPanel x:Name="AccountPanel" IsVisible="{Binding !!Wallets.Count}" Spacing="16" Orientation="Horizontal">
                        <TextBlock VerticalAlignment="Center" IsVisible="{Binding TotalInvested.IsPositive, FallbackValue=False}">
                            <TextBlock.Inlines>
                                <Run Classes="Thin">Invested:</Run>
                                <Run Classes="Label" Text="{Binding TotalInvested.ShortDecimalString, FallbackValue='0'}" />
                            </TextBlock.Inlines>
                        </TextBlock>
                        <TextBlock VerticalAlignment="Center">
                            <TextBlock.Inlines>
                                <Run Classes="Thin">Available:</Run>
                                <Run Classes="Label" Text="{Binding CurrentWallet.Balance.ShortDecimalString, FallbackValue='0'}" />
                            </TextBlock.Inlines>
                        </TextBlock>
                        <ComboBox SelectedItem="{Binding CurrentWallet}" VerticalAlignment="Center" ItemsSource="{Binding Wallets}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <EdgePanel IconOptions.Size="18" Foreground="{DynamicResource TextMuted}" StartContent="{Icon fa-wallet}" Content="{Binding Name}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>
                    <ToggleButton Classes="Widget" IsChecked="{Binding IsDarkThemeEnabled, Mode=TwoWay}">
                        <ToggleButton.Content>
                            <PathIcon Foreground="{DynamicResource TextMuted}" Data="{DynamicResource Sun}" />
                        </ToggleButton.Content>
                    </ToggleButton>
                    <EnhancedButton Classes="Widget" Icon="{Icon mdi-cog}" Command="{Binding GoToSettings}" />
                </StackPanel>
            </DockPanel>
        </DockPanel>
        <SectionStrip Classes="Nav" Grid.Row="1" Grid.Column="0" SelectedSection="{Binding SelectedSection}" IconSize="24" Width="200" HorizontalAlignment="Left" Sections="{Binding SidebarSections}" />
        <OverlayBorder Grid.Row="1" Grid.Column="1" Classes="Panel" Padding="0" Background="{DynamicResource TiledLogoBrush}">
            <Frame Content="{Binding SelectedSection.Navigator.Content^}" BackCommand="{Binding SelectedSection.Navigator.Back}">
                <Interaction.Behaviors>
                    <AutoHeaderFooterBehavior />
                </Interaction.Behaviors>
            </Frame>
        </OverlayBorder>
    </Grid>
--></UserControl>