<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:shell="clr-namespace:AngorApp.UI.Shell"
             mc:Ignorable="d" d:DesignWidth="800"
             x:DataType="shell:IShellViewModel"
             x:Class="AngorApp.UI.Shell.InfoBar">
    <DockPanel>
        <DockPanel DockPanel.Dock="Top" HorizontalSpacing="20">
            <TextBlock FontWeight="Bold" VerticalAlignment="Center" FontSize="20"
                       Text="{Binding SelectedSection.FriendlyName}" />
            <Border IsVisible="{Binding ProfileName, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                    Background="{DynamicResource Brand}" CornerRadius="4" Padding="8 2" VerticalAlignment="Center">
                <TextBlock Text="{Binding ProfileName}" FontSize="12" Foreground="White" />
            </Border>
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Right" Spacing="16" Orientation="Horizontal">
                <StackPanel x:Name="AccountPanel" IsVisible="{Binding !!Wallets.Count}" Spacing="16"
                            Orientation="Horizontal">
                    <TextBlock VerticalAlignment="Center"
                               IsVisible="{Binding TotalInvested.IsPositive, FallbackValue=False}">
                        <TextBlock.Inlines>
                            <Run Classes="Thin">Invested:</Run>
                            <Run Classes="Label" Text="{Binding TotalInvested.ShortDecimalString, FallbackValue='0'}" />
                        </TextBlock.Inlines>
                    </TextBlock>
                    <TextBlock VerticalAlignment="Center">
                        <TextBlock.Inlines>
                            <Run Classes="Thin">Available:</Run>
                            <Run Classes="Label"
                                 Text="{Binding CurrentWallet.Balance.ShortDecimalString, FallbackValue='0'}" />
                        </TextBlock.Inlines>
                    </TextBlock>
                    <ComboBox SelectedItem="{Binding CurrentWallet}" VerticalAlignment="Center"
                              ItemsSource="{Binding Wallets}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <EdgePanel IconOptions.Size="18" Foreground="{DynamicResource TextMuted}"
                                           StartContent="{Icon fa-wallet}" Content="{Binding Name}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>
                <ToggleButton Classes="Widget" IsChecked="{Binding IsDarkThemeEnabled, Mode=TwoWay}">
                    <ToggleButton.Content>
                        <PathIcon Foreground="{DynamicResource TextMuted}" Data="{DynamicResource Sun}" />
                    </ToggleButton.Content>
                </ToggleButton>
                <EnhancedButton Classes="Widget" Icon="{Icon mdi-cog}" Command="{Binding GoToSettings}" />
            </StackPanel>
        </DockPanel>
    </DockPanel>
</UserControl>