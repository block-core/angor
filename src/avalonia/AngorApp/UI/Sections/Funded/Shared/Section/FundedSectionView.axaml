<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="clr-namespace:AngorApp.UI.Shared.Controls"
             xmlns:section="clr-namespace:AngorApp.UI.Sections.Funded.Shared.Section"
             xmlns:projectList="clr-namespace:AngorApp.UI.Sections.Funded.Shared.ProjectList"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="400"
             x:Class="AngorApp.UI.Sections.Funded.Shared.Section.FundedSectionView" x:DataType="section:IFundedSectionViewModel">

    <Design.DataContext>
        <section:FundedSectionViewModelSample />
    </Design.DataContext>

    <Interaction.Behaviors>
        <LoadedTrigger>
            <InvokeCommandAction Command="{Binding Refresh}" />
        </LoadedTrigger>
    </Interaction.Behaviors>

    <Loading IsLoading="{Binding Refresh.IsExecuting^}" LoadingText="Loading. Please wait.">
        <Panel>
            <projectList:ProjectListView IsVisible="{Binding !!FundedItems.Count}" />
            <projectList:EmptyView VerticalAlignment="Center" IsVisible="{Binding !!!FundedItems.Count}" />
        </Panel>
    </Loading>
</UserControl>