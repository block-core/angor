            <!--     <FlexPanel Direction="Row" Wrap="Wrap" ColumnGap="16" RowGap="4" Margin="6 0"> -->
            <!--         <StackPanel> -->
            <!--             <TextBlock Classes="Weight-Bold Strong" Text="{Binding Wallet.Balance.DecimalString}" /> -->
            <!--             <TextBlock Classes="Weight-Light Dimmed" Text="Balance" FontSize="10" /> -->
            <!--         </StackPanel> -->
            <!--         <StackPanel IsVisible="{Binding Wallet.UnconfirmedBalance.IsPositive}"> -->
            <!--             <TextBlock Classes="Weight-Bold" Foreground="{DynamicResource Warning}" -->
            <!--                        Text="{Binding Wallet.UnconfirmedBalance.DecimalString}" /> -->
            <!--             <TextBlock Classes="Weight-Light Dimmed" Text="Pending" FontSize="10" /> -->
            <!--         </StackPanel> -->
            <!--         <StackPanel IsVisible="{Binding Wallet.ReservedBalance.IsPositive}"> -->
            <!--             <TextBlock Classes="Weight-Bold" Foreground="{DynamicResource Info}" -->
            <!--                        Text="{Binding Wallet.ReservedBalance.DecimalString}" /> -->
            <!--             <TextBlock Classes="Weight-Light Dimmed" Text="Reserved" FontSize="10" /> -->
            <!--         </StackPanel> -->
            <!--     </FlexPanel> -->
            <!--     <ItemsControl ItemsSource="{Binding Wallet.Labels}" Classes="Horizontal" /> -->
            <!--     <FlexPanel Direction="Row" Gap="8"> -->
            <!--         <EnhancedButton Command="{Binding Send}" Height="32" Width="32" CornerRadius="6" Padding="7" -->
            <!--                         Icon="{Icon fa-arrow-up}" Classes="Emphasized" /> -->
            <!--         <EnhancedButton Command="{Binding Receive}" Height="32" Width="32" CornerRadius="6" Padding="7" -->
            <!--                         Icon="{Icon fa-arrow-down}" Classes="Outline" /> -->
