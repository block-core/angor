            <!--     <EdgePanel StartContent="{Icon fa-bitcoin}" -->
            <!--                Classes="Icon-M Icon-Bg-LightGray Icon-Square"> -->
            <!--         <StackPanel VerticalAlignment="Center" Classes="Gap-S"> -->
            <!--             <TextBlock Classes="Weight-Bold Strong" Text="{Binding Wallet.Name}" /> -->
            <!--             <TextBlock Classes="Weight-Light Dimmed" Text="{Binding Wallet.NetworkKind}" /> -->
            <!--         </StackPanel> -->
            <!--     </EdgePanel> -->
            <!-- </EdgePanel.StartContent> -->
