<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:newShell="clr-namespace:AngorApp.UI.NewShell"
             xmlns:new="clr-namespace:AngorApp.UI.Sections.New"
             xmlns:controls="clr-namespace:AngorApp.UI.Shared.Controls"
             xmlns:generic="clr-namespace:System.Collections.Generic;assembly=System.Collections"
             mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="650"
             x:Class="AngorApp.UI.NewShell.Shell" x:DataType="newShell:IShellViewModel" Background="{StaticResource Background}">

    <Design.DataContext>
        <newShell:ShellViewModelSample />
    </Design.DataContext>

