<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:newShell="clr-namespace:AngorApp.UI.NewShell"
             xmlns:new="clr-namespace:AngorApp.UI.Sections.New"
             mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="650"
             x:Class="AngorApp.UI.NewShell.Shell" x:DataType="newShell:IShellViewModel" Background="{StaticResource Background}">

    <Design.DataContext>
        <newShell:ShellViewModelSample />
    </Design.DataContext>

    <DockPanel>
        <!-- <Svg Margin="24" Height="32" Width="32" Path="/Assets/logo.svg"  HorizontalAlignment="Center" /> -->
        <SectionStrip Classes="Nav" Grid.Row="1" SelectedSection="{Binding SelectedSection}" IconSize="24" Width="200" HorizontalAlignment="Left" Sections="{Binding SidebarSections}" />
        <DockPanel Grid.Row="1" Grid.Column="1">
            <DockPanel Margin="0 20 20 20" VerticalSpacing="20">
                <DockPanel DockPanel.Dock="Top" HorizontalSpacing="20">
                    <TextBlock FontWeight="Bold" VerticalAlignment="Center" FontSize="20" Text="{Binding SelectedSection.FriendlyName}" />
                    <StackPanel HorizontalAlignment="Right"  Spacing="20" Orientation="Horizontal">
                        <ComboBox VerticalAlignment="Center" />
                        <!-- <EnhancedButton Tint="White" BorderThickness="1" Icon="{Icon fa-sun}" /> -->
                        <!-- <EnhancedButton Tint="White" BorderThickness="1" Icon="{Icon fa-cog}" /> -->
                    </StackPanel>
                </DockPanel>
                <Border Classes="Regular">
                    <new:HomeView />
                </Border>
            </DockPanel>
        </DockPanel>
    </DockPanel>
</UserControl>
