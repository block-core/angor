    </UserControl.Resources>

    <UserControl.Styles>
        <Style Selector="EnhancedButton.Widget">
            <Setter Property="Background" Value="{StaticResource Overbackground}" />
            <Setter Property="BorderBrush" Value="{StaticResource Border}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{StaticResource Text}" />
            <Setter Property="Padding" Value="10" />
            <Setter Property="Height" Value="42" />
        </Style>
        <Style Selector="ComboBox">
            <Setter Property="Background" Value="{StaticResource Overbackground}" />
            <Setter Property="BorderBrush" Value="{StaticResource Border}" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Height" Value="42"></Setter>
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{StaticResource Text}" />
            <Setter Property="Padding" Value="12" />
            <Setter Property="FontWeight" Value="Bold"></Setter>
        </Style>
        <Style Selector="ComboBox:pointerover /template/ Border">
            <Setter Property="Background" Value="{StaticResource Overbackground}" />
        </Style>
    </UserControl.Styles>

    <Grid x:Name="TopBar" Margin="0 20 20 20" ColumnDefinitions="Auto *" RowDefinitions="42 *" ColumnSpacing="20" RowSpacing="20">
        <PathIcon Height="32" Foreground="{StaticResource Accent}" Width="32" Data="{StaticResource Logo}" />
        <DockPanel Grid.Row="0" Grid.Column="1" Dock="Top">
            <DockPanel DockPanel.Dock="Top" HorizontalSpacing="20">
                <TextBlock FontWeight="Bold" VerticalAlignment="Center" FontSize="20" Text="{Binding SelectedSection.FriendlyName}" />
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Right" Spacing="16" Orientation="Horizontal">
                    <TextBlock VerticalAlignment="Center">
                        <TextBlock.Inlines>
                            <Run Classes="Thin">Invested:</Run>
                            <Run Classes="Label">0.0000 BTC</Run>
                        </TextBlock.Inlines>
                    </TextBlock>
                    <TextBlock VerticalAlignment="Center">
                        <TextBlock.Inlines>
                            <Run Classes="Thin">Available:</Run>
                            <Run Classes="Label">10.0000 BTC</Run>
                        </TextBlock.Inlines>
                    </TextBlock>
                    <ComboBox SelectedIndex="0" VerticalAlignment="Center">
                        <ComboBox.ItemsSource>
                            <generic:List x:TypeArguments="x:String">
                                <x:String>Mainnet</x:String>
                                <x:String>Testnet</x:String>
                                <x:String>Liquid</x:String>
                                <x:String>Ecash</x:String>
                            </generic:List>
                        </ComboBox.ItemsSource>
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <EdgePanel IconOptions.Size="18" Foreground="{StaticResource Text}" StartContent="{Icon mdi-web}" Content="{Binding}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <EnhancedButton Classes="Widget">
                        <EnhancedButton.Icon>
                            <PathIcon Foreground="{StaticResource Text}" Data="{StaticResource Sun}" />
                        </EnhancedButton.Icon>
                    </EnhancedButton>
                    <EnhancedButton Classes="Widget" Icon="{Icon mdi-cog}" Command="{Binding GoToSettings}" />
                </StackPanel>
            </DockPanel>
        </DockPanel>
        <SectionStrip Classes="Nav" Grid.Row="1" SelectedSection="{Binding SelectedSection}" IconSize="24" Width="200" HorizontalAlignment="Left" Sections="{Binding SidebarSections}" />
        <Border Grid.Row="1" Grid.Column="1" Classes="Regular">
            <Frame Navigator="{Binding Navigator}" />
        </Border>
    </Grid>
</UserControl>