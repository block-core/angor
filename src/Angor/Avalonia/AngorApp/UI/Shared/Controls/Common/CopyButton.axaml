<ResourceDictionary xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:c="using:AngorApp.UI.Shared.Controls.Common">
    <Design.PreviewWith>
        <c:CopyButton />
    </Design.PreviewWith>

    <ControlTheme x:Key="{x:Type c:CopyButton}" TargetType="{x:Type c:CopyButton}">
        <Setter Property="Template">
            <ControlTemplate>
                <EnhancedButton IconOptions.Size="16" CommandParameter="{TemplateBinding Content}" 
                                Command="{Binding CopyParameter, Source={x:Static Commands.Instance}}" 
                                Classes="Widget" 
                                Icon="{Icon fa-copy}" />
            </ControlTemplate>
        </Setter>
    </ControlTheme>
</ResourceDictionary>
