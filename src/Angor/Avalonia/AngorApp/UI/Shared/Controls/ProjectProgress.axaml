<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:p="clr-namespace:AngorApp.Model.ProjectsV2;assembly=AngorApp.Model"
             xmlns:investmentProject="clr-namespace:AngorApp.Model.ProjectsV2.InvestmentProject;assembly=AngorApp.Model"
             xmlns:fundProject="clr-namespace:AngorApp.Model.ProjectsV2.FundProject;assembly=AngorApp.Model"
             xmlns:samples="clr-namespace:AngorApp.Model.Funded.Investment.Samples;assembly=AngorApp.Model"
             mc:Ignorable="d"
             x:Class="AngorApp.UI.Shared.Controls.ProjectProgress" x:DataType="p:IProject">
    
    <Design.DataContext>
        <samples:InvestmentProjectSample />
    </Design.DataContext>
    
    <UserControl.Styles>
        <Style Selector="ProgressBar">
            <Setter Property="Height" Value="8" />
        </Style>
    </UserControl.Styles>
    
    <ContentControl Content="{Binding}">
        <ContentControl.DataTemplates>
            <DataTemplate DataType="investmentProject:IInvestmentProject">
                <ProgressBar Value="{Binding Raised^.Sats}" Maximum="{Binding Target.Sats}" IsIndeterminate="{Binding Refresh.IsExecuting^}" />
            </DataTemplate>
            <DataTemplate DataType="fundProject:IFundProject">
                <ProgressBar Value="{Binding Funded^.Sats}" Maximum="{Binding Goal.Sats}" IsIndeterminate="{Binding Refresh.IsExecuting^}" />
            </DataTemplate>
        </ContentControl.DataTemplates>
    </ContentControl>
</UserControl>