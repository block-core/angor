<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:l="clr-namespace:AngorApp.UI.Sections.FindProjects.Details"
             xmlns:a="clr-namespace:AsyncImageLoader;assembly=AsyncImageLoader.Avalonia"
             xmlns:c="clr-namespace:AngorApp.UI.Shared.Controls"
             xmlns:cm="clr-namespace:AngorApp.UI.Shared.Controls.Common"
             xmlns:cards="clr-namespace:AngorApp.UI.Sections.FindProjects.Details.Cards"
             xmlns:inv="clr-namespace:AngorApp.Model.ProjectsV2.InvestmentProject;assembly=AngorApp.Model"
             xmlns:fund="clr-namespace:AngorApp.Model.ProjectsV2.FundProject;assembly=AngorApp.Model"
             mc:Ignorable="d"
             x:Class="AngorApp.UI.Sections.FindProjects.Details.DetailsView"
             x:DataType="l:IDetailsViewModel">

    <Design.DataContext>
        <l:DetailsViewModelSample />
    </Design.DataContext>

    <c:ScrollableView>
        <StackPanel Spacing="30" Margin="20" MaxWidth="1200" HorizontalAlignment="Stretch">

            <!-- Top Section: Header + Investment Opportunity -->
            <Grid ColumnDefinitions="*, 400" ColumnSpacing="20">

                <!-- Left Column: Header & Description -->
                <OverlayBorder Classes="White Shadow" Padding="0" CornerRadius="16">
                    <StackPanel Grid.Column="0">
                        <a:AdvancedImage CornerRadius="10 10 0 0" Margin="-20 -20 -20 0" Stretch="UniformToFill" Height="140" Source="{Binding Project.BannerUrl}" />
                        <Panel>
                            <Border Classes="Shadow" Height="60" Width="60" Margin="20 -30 0 0" HorizontalAlignment="Left" CornerRadius="30" />
                            <Border Height="60" Width="60" Margin="20 -30 0 0" HorizontalAlignment="Left" CornerRadius="30" ClipToBounds="True" Background="{DynamicResource AppBackground}">
                                <a:AdvancedImage Source="{Binding Project.LogoUrl}" />
                            </Border>
                        </Panel>
                        <StackPanel Margin="20" Classes="Gap-S">
                            <TextBlock Text="{Binding Project.Name}" TextWrapping="Wrap" Classes="Weight-Bold Size-XL Strong" />
                            <TextBlock Text="{Binding Project.Description}" TextTrimming="{x:Static TextTrimming.CharacterEllipsis}" TextWrapping="Wrap" Classes="Size-M" />
                        </StackPanel>
                    </StackPanel>
                </OverlayBorder>

                <!-- Right Column: Investment Opportunity -->
                <ContentControl Grid.Column="1" ClipToBounds="False" Content="{Binding Project}">
                    <ContentControl.DataTemplates>
                        <DataTemplate DataType="inv:IInvestmentProject">
                            <Panel Classes="Gap-XL">
                                <cards:InvestmentOpenCard>
                                    <cards:InvestmentOpenCard.IsVisible>
                                        <Binding Path="IsFundingOpen^" />
                                    </cards:InvestmentOpenCard.IsVisible>
                                </cards:InvestmentOpenCard>

                                <cards:InvestmentFailedCard>
                                    <cards:InvestmentFailedCard.IsVisible>
                                        <Binding Path="IsFundingFailed^" />
                                    </cards:InvestmentFailedCard.IsVisible>
                                </cards:InvestmentFailedCard>

                                <cards:InvestmentSuccessfulCard>
                                    <cards:InvestmentSuccessfulCard.IsVisible>
                                        <Binding Path="IsFundingSuccessful^" />
                                    </cards:InvestmentSuccessfulCard.IsVisible>
                                </cards:InvestmentSuccessfulCard>
                            </Panel>
                        </DataTemplate>

                        <DataTemplate DataType="fund:IFundProject">
                            <cards:FundOpenCard />
                        </DataTemplate>
                    </ContentControl.DataTemplates>
                </ContentControl>
            </Grid>

            <!-- Project Statistics (dispatched by project type) -->
            <HeaderedContainer Classes="Card ApricotGradient Shadow BigHeader">
                <HeaderedContainer.Header>
                    <EdgePanel StartContent="{Icon fa-bitcoin}" Content="Project Statistics " />
                </HeaderedContainer.Header>
                <ContentControl ClipToBounds="False" Content="{Binding Project}">
                    <ContentControl.DataTemplates>
                        <DataTemplate DataType="inv:IInvestmentProject">
                            <StackPanel Spacing="15">
                                <UniformGrid Columns="3" Margin="0 10" ColumnSpacing="16">
                                    <c:NewCard ContainerClasses="Card ApricotBorder" Left="Target Amount" Content="{Binding Target.DecimalString}" Right="{Icon fa-bitcoin}" LeftClasses="BrownText" ContentClasses="Size-XL" />
                                    <c:NewCard ContainerClasses="Card ApricotBorder" Left="Total Raised" Content="{Binding Raised^.DecimalString}" Right="{Icon fa-clock}" LeftClasses="BrownText" ContentClasses="Size-XL" />
                                    <c:NewCard ContainerClasses="Card ApricotBorder" Left="Total Investors" Content="{Binding InvestorCount^}" Right="{Icon fa-clipboard}" LeftClasses="BrownText" ContentClasses="Size-XL" />
                                </UniformGrid>
                                <StackPanel Classes="Gap-M">
                                    <Grid ColumnDefinitions="*, Auto" Margin="0 0 0 5">
                                        <TextBlock Text="Funding Progress" Foreground="#4a4a4a" Classes="Size-S Weight-Bold" />
                                    </Grid>
                                    <c:ProjectProgress />
                                </StackPanel>
                            </StackPanel>
                        </DataTemplate>
                        <DataTemplate DataType="fund:IFundProject">
                            <StackPanel Spacing="15">
                                <UniformGrid Columns="3" Margin="0 10" ColumnSpacing="16">
                                    <c:NewCard ContainerClasses="Card ApricotBorder" Left="Goal Amount" Content="{Binding Goal.DecimalString}" Right="{Icon fa-bitcoin}" LeftClasses="BrownText" ContentClasses="Size-XL" />
                                    <c:NewCard ContainerClasses="Card ApricotBorder" Left="Total Funded" Content="{Binding Funded^.DecimalString}" Right="{Icon fa-clock}" LeftClasses="BrownText" ContentClasses="Size-XL" />
                                    <c:NewCard ContainerClasses="Card ApricotBorder" Left="Total Funders" Content="{ReflectionBinding FunderCount^, FallbackValue=0}" Right="{Icon fa-clipboard}" LeftClasses="BrownText" ContentClasses="Size-XL" />
                                </UniformGrid>
                                <StackPanel Classes="Gap-M">
                                    <Grid ColumnDefinitions="*, Auto" Margin="0 0 0 5">
                                        <TextBlock Text="Funding Progress" Foreground="#4a4a4a" Classes="Size-S Weight-Bold" />
                                    </Grid>
                                    <c:ProjectProgress />
                                </StackPanel>
                            </StackPanel>
                        </DataTemplate>
                    </ContentControl.DataTemplates>
                </ContentControl>
            </HeaderedContainer>

            <!-- Funding Information (dispatched by project type) -->
            <ContentControl Content="{Binding Project}" IsVisible="{Binding $self.Content, Converter={x:Static ObjectConverters.Equal}, ConverterParameter={x:Type inv:IInvestmentProject}}">
                <ContentControl.DataTemplates>
                    <DataTemplate DataType="inv:IInvestmentProject">
                        <HeaderedContainer Classes="Card White Shadow BigHeader">
                            <HeaderedContainer.Header>
                                <EdgePanel StartContent="{Icon fa-bitcoin}">Investment Information</EdgePanel>
                            </HeaderedContainer.Header>
                            <UniformGrid Columns="3" Margin="0 10" ColumnSpacing="16" RowSpacing="16">
                                <c:NewCard ContainerClasses="Card ApricotBorder ThickBorder" Center="Funding Start" Content="{Binding FundingStart, StringFormat=m}" Right="{Icon fa-calendar}" HeaderPanelClasses="" />
                                <c:NewCard ContainerClasses="Card ApricotBorder ThickBorder" Center="Funding End" Content="{Binding FundingEnd, StringFormat=m}" Right="{Icon fa-calendar}" HeaderPanelClasses="" />
                                <c:NewCard ContainerClasses="Card ApricotBorder ThickBorder" Center="Stages" Content="{Binding Stages^.Count, FallbackValue=...}" Right="{Icon fa-layer-group}" HeaderPanelClasses="" />
                            </UniformGrid>
                        </HeaderedContainer>
                    </DataTemplate>
                    <DataTemplate DataType="fund:IFundProject">
                        <!-- TODO: NOTHING FOR NOW -->
                    </DataTemplate>
                </ContentControl.DataTemplates>
            </ContentControl>

            <!-- Expandable: Project Details -->
            <Expander IsExpanded="False">
                <Expander.Header>
                    <EdgePanel StartContent="{Icon fa-circle-info}" Content="Project Details" />
                </Expander.Header>
                <StackPanel Spacing="15" Margin="10">

                    <HeaderedContainer Header="Explorer">
                        <EdgePanel Classes="ColorPanel LightGray Radius-S SmallerPadding" StartContent="{Icon fa-arrow-up-right-from-square}">
                            <EdgePanel.Content>
                                <HyperlinkButton Grid.Column="1" NavigateUri="{Binding ExplorerUrl}" Content="View the transaction" HorizontalAlignment="Left" Padding="0" />
                            </EdgePanel.Content>
                        </EdgePanel>
                    </HeaderedContainer>

                    <HeaderedContainer Header="Project ID">
                        <EdgePanel Classes="ColorPanel LightGray SmallerPadding Radius-S" StartContent="{Icon fa-cloud}">
                            <EdgePanel.Content>
                                <EdgePanel Content="{Binding ProjectId}">
                                    <EdgePanel.EndContent>
                                        <cm:CopyButton Content="{Binding ProjectId}" />
                                    </EdgePanel.EndContent>
                                </EdgePanel>
                            </EdgePanel.Content>
                        </EdgePanel>
                    </HeaderedContainer>
                    <HeaderedContainer Header="Founder Key">
                        <EdgePanel Classes="ColorPanel LightGray SmallerPadding Radius-S" StartContent="{Icon fa-key}">
                            <EdgePanel.Content>
                                <EdgePanel Content="{Binding FounderKey}">
                                    <EdgePanel.EndContent>
                                        <cm:CopyButton Content="{Binding FounderKey}" />
                                    </EdgePanel.EndContent>
                                </EdgePanel>
                            </EdgePanel.Content>
                        </EdgePanel>
                    </HeaderedContainer>

                    <EnhancedButton Command="{Binding ShowProjectInfoJson}"
                                    Content="Show Project Info (JSON)"
                                    Icon="{Icon fa-code}"
                                    HorizontalAlignment="Left"
                                    Classes="Accent" />
                </StackPanel>
            </Expander>

            <!-- Expandable: Nostr -->
            <Expander>
                <Expander.Header>
                    <EdgePanel StartContent="{Icon fa-comment-dots}" Content="Nostr" />
                </Expander.Header>

                <StackPanel Spacing="15" Margin="10">

                    <HeaderedContainer Header="Nostr Public Key (npub)">
                        <EdgePanel Classes="ColorPanel LightGray SmallerPadding Radius-S" StartContent="{Icon fa-user}">
                            <EdgePanel.Content>
                                <EdgePanel Content="{Binding NostrNpub}">
                                    <EdgePanel.EndContent>
                                        <cm:CopyButton Content="{Binding NostrNpub}" />
                                    </EdgePanel.EndContent>
                                </EdgePanel>
                            </EdgePanel.Content>
                        </EdgePanel>
                    </HeaderedContainer>
                    <HeaderedContainer Header="Nostr Public Key (hex)">
                        <EdgePanel Classes="ColorPanel LightGray SmallerPadding Radius-S" StartContent="{Icon fa-hashtag}">
                            <EdgePanel.Content>
                                <EdgePanel Content="{Binding NostrHex}">
                                    <EdgePanel.EndContent>
                                        <cm:CopyButton Content="{Binding NostrHex}" />
                                    </EdgePanel.EndContent>
                                </EdgePanel>
                            </EdgePanel.Content>
                        </EdgePanel>
                    </HeaderedContainer>

                    <HeaderedContainer Header="Relays">
                        <ItemsControl Classes="Vertical" ItemsSource="{Binding Relays}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <EdgePanel Classes="ColorPanel LightGray SmallerPadding Radius-S" StartContent="{Icon fa-bolt}" Content="{Binding}" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </HeaderedContainer>
                </StackPanel>
            </Expander>

        </StackPanel>
    </c:ScrollableView>
</UserControl>