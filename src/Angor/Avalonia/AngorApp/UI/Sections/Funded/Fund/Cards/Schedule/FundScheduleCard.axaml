<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:p="clr-namespace:AngorApp.Model.Funded.Fund.Model;assembly=AngorApp.Model"
             xmlns:samples="clr-namespace:AngorApp.Model.Funded.Fund.Model;assembly=AngorApp.Model"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="AngorApp.UI.Sections.Funded.Fund.Cards.Schedule.FundScheduleCard" x:DataType="p:IFundFunded">

    <Design.DataContext>
        <samples:FundFundedSample />
    </Design.DataContext>

    <SlimDataGrid ItemsSource="{Binding PaymentsWithStatus^}">
        <SlimDataGrid.Columns>
            <Column Header="Stage" Binding="{Binding Id, StringFormat='Payment {0}', Converter={x:Static MiscConverters.AddOne}}" />
            <Column Header="Payment Date" Binding="{Binding PaymentDate, StringFormat=m}" />
            <Column Header="Status" Binding="{Binding Status}" />
            <Column Header="Amount Per Payment" Binding="{Binding Path=Amount.DecimalString}" />
        </SlimDataGrid.Columns>
    </SlimDataGrid>
</UserControl>