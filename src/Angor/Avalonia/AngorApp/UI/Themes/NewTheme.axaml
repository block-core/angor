<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <FluentTheme />
    
    <Styles.Resources>
        <SolidColorBrush x:Key="Background" Color="#F9F9F9" />
        <SolidColorBrush x:Key="Overbackground" Color="{DynamicResource SystemChromeWhiteColor}" />
        <SolidColorBrush x:Key="Border" Color="#E8E8E8" />
        <SolidColorBrush x:Key="Text" Color="#6B7280" />
        <SolidColorBrush x:Key="Accent" Color="#2D5A3D" />
        <SolidColorBrush x:Key="Strong" Color="#0A0A0A" />
        <SolidColorBrush x:Key="HoverBackground" Color="#E9E9E9" />
        <SolidColorBrush x:Key="SelectedBackground" Color="White" />
    </Styles.Resources>

    <Style Selector=":is(UserControl)">
        <Setter Property="Foreground" Value="{StaticResource Text}" />
    </Style>
    
    <Style Selector="Border.Regular">
        <Setter Property="CornerRadius" Value="20" />
        <Setter Property="Padding" Value="20" />
        <Setter Property="BorderBrush" Value="{StaticResource Border}" />
        <Setter Property="BorderThickness" Value="2" />
        <Setter Property="Background" Value="{StaticResource Overbackground}" />
    </Style>

    <Style Selector="SectionStrip.Nav SectionStripGroupHeader">
        <Setter Property="Foreground" Value="{StaticResource Accent}" />
        <Setter Property="FontFamily" Value="Sans Serif" />
        <Setter Property="FontWeight" Value="SemiLight" />
        <Setter Property="FontSize" Value="18" />
        <Setter Property="Margin" Value="10" />
    </Style>

    <Style Selector="SectionStrip.Nav SectionStripItem">
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Padding" Value="8" />
        <Setter Property="Margin" Value="10" />
        <Setter Property="Foreground" Value="{StaticResource Text}" />
        <Setter Property="ClipToBounds" Value="False" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style Selector="SectionStrip.Nav SectionStripItem:pointerover">
        <Setter Property="Background" Value="{StaticResource HoverBackground}" />
    </Style>

    <Style Selector="SectionStrip.Nav SectionStripItem:selected">
        <Setter Property="Background" Value="{StaticResource SelectedBackground}" />
        <Setter Property="Foreground" Value="{StaticResource Accent}" />
    </Style>

    <Style Selector="SectionStrip.Nav SectionStripItem:selected Border">
        <Setter Property="BoxShadow" Value="0 0 30 0 LightGray" />
        <Setter Property="BorderBrush" Value="{StaticResource Border}" />
    </Style>

    <Style Selector="TextBlock">
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>
    
    <Style Selector="TextBlock.Center">
        <Setter Property="TextAlignment" Value="Center" />
    </Style>
    
    <Style Selector="TextBlock.Title">
        <Setter Property="FontSize" Value="25" />
        <Setter Property="FontWeight" Value="Bold" />
    </Style>
    
    <Style Selector="TextBlock.Subtitle">
        <Setter Property="FontSize" Value="18" />
        <Setter Property="FontWeight" Value="SemiLight" />
    </Style>
    
    <Style Selector="TextBlock.TitleStrong">
        <Setter Property="FontSize" Value="25" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{StaticResource Strong}" />
    </Style>
    
    <Design.PreviewWith>
        <Border Classes="Regular" Width="200" Height="200">
            <TextBlock>HOLA</TextBlock>
        </Border>
    </Design.PreviewWith>

</Styles>
