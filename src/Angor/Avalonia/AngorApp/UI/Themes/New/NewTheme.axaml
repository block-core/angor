<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <FluentTheme />
    <StyleInclude Source="avares://Zafiro.Avalonia/Styles.axaml" />
    <StyleInclude Source="avares://Zafiro.Avalonia.Dialogs/Styles.axaml" />
    <StyleInclude Source="avares://AsyncImageLoader.Avalonia/AdvancedImage.axaml" />

    <StyleInclude Source="Custom/EnhancedButton.axaml" />
    <StyleInclude Source="/UI/Shared/Styles/Styles.axaml" />

    <StyleInclude Source="/UI/Shared/Styles/Styles.axaml" />
    <StyleInclude Source="/UI/Shared/Controls/Pane.axaml" />
    <StyleInclude Source="/UI/Shared/Controls/AmountControl.axaml" />
    <StyleInclude Source="/UI/Shared/Controls/List.axaml" />
    <StyleInclude Source="/UI/Shared/Controls/IconLabel.axaml" />
    <StyleInclude Source="/UI/Shared/Controls/ProjectCard.axaml" />
    <StyleInclude Source="/UI/Shared/Controls/Feerate/FeerateSelector.axaml" />
    <StyleInclude Source="/UI/Shared/Controls/ErrorSummary.axaml" />
    <StyleInclude Source="/UI/Sections/Wallet/CreateAndImport/Steps/SeedWordsGeneration/SeedWordList.axaml" />
    <StyleInclude Source="/UI/Shared/Controls/PageContainer.axaml" />
    <StyleInclude Source="/UI/Shared/Controls/Badge.axaml" />
    <StyleInclude Source="/UI/Shared/Styles/Cards.axaml" />
    <StyleInclude Source="/UI/Shared/Styles/TextBox.axaml" />
    <StyleInclude Source="/UI/Shared/Styles/OverlayBorder.axaml" />
    <StyleInclude Source="/UI/Shared/Styles/CalendarDatePicker.axaml" />
    <StyleInclude Source="/UI/Shared/Styles/TextBlock.axaml" />
    <StyleInclude Source="/UI/Shared/Styles/ToggleButton.axaml" />
    <StyleInclude Source="/UI/Shared/Styles/FlyoutPresenter.axaml" />
    <StyleInclude Source="/UI/Shared/Styles/Button.axaml" />
    <StyleInclude Source="/UI/Shared/Styles/Automation.axaml" />
    <StyleInclude Source="/UI/Shared/Styles/SlimDataGrid.axaml" />
    <StyleInclude Source="/UI/Shared/Styles/HeaderedContainer.axaml" />
    <StyleInclude Source="/UI/Shared/Styles/EdgePanel.axaml" />
    <StyleInclude Source="/UI/Shared/Styles/Border.axaml" />
    <StyleInclude Source="/UI/Shared/Styles/ShellView.axaml" />

    <Styles.Resources>
        <ResourceDictionary>
            <SolidColorBrush x:Key="Background" Color="#F9F9F9" />
            <SolidColorBrush x:Key="Overbackground" Color="White" />
            <SolidColorBrush x:Key="Border" Color="#E8E8E8" />
            <SolidColorBrush x:Key="Text" Color="#6B7280" />
            <SolidColorBrush x:Key="Accent" Color="#2D5A3D" />
            <SolidColorBrush x:Key="Strong" Color="#0A0A0A" />
            <SolidColorBrush x:Key="HoverBackground" Color="#E9E9E9" />
            <SolidColorBrush x:Key="SelectedBackground" Color="White" />
            
        </ResourceDictionary>
    </Styles.Resources>

    <Style Selector=":is(UserControl)">
        <Setter Property="Foreground" Value="{StaticResource Text}" />
    </Style>

    <Style Selector="Border.Regular">
        <Setter Property="CornerRadius" Value="20" />
        <Setter Property="Padding" Value="20" />
        <Setter Property="BorderBrush" Value="{StaticResource Border}" />
        <Setter Property="BorderThickness" Value="2" />
        <Setter Property="Background" Value="{StaticResource Overbackground}" />
    </Style>

    <Style Selector="SectionStrip.Nav SectionStripGroupHeader">
        <Setter Property="Foreground" Value="{StaticResource Accent}" />
        <Setter Property="FontFamily" Value="Sans Serif" />
        <Setter Property="FontWeight" Value="SemiLight" />
        <Setter Property="FontSize" Value="18" />
        <Setter Property="Margin" Value="10" />
    </Style>

    <Style Selector="SectionStrip.Nav SectionStripItem">
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Padding" Value="8" />
        <Setter Property="Margin" Value="10" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{StaticResource Text}" />
        <Setter Property="ClipToBounds" Value="False" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style Selector="SectionStrip.Nav SectionStripItem:pointerover">
        <Setter Property="Background" Value="{StaticResource HoverBackground}" />
    </Style>

    <Style Selector="SectionStrip.Nav SectionStripItem:selected">
        <Setter Property="Background" Value="{StaticResource SelectedBackground}" />
        <Setter Property="Foreground" Value="{StaticResource Accent}" />
    </Style>

    <Style Selector="SectionStrip.Nav SectionStripItem:selected Border">
        <Setter Property="BoxShadow" Value="0 0 30 0 LightGray" />
        <Setter Property="BorderBrush" Value="{StaticResource Border}" />
    </Style>

    <Style Selector="TextBlock">
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style Selector="TextBlock.Label">
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{StaticResource Text}" />
    </Style>

    <Style Selector="Run.Label">
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{StaticResource Text}" />
    </Style>

    <Style Selector="Run.Thin">
        <Setter Property="FontWeight" Value="SemiLight" />
        <Setter Property="Foreground" Value="{StaticResource Text}" />
    </Style>

    <Style Selector=":is(TemplatedControl).Center">
        <Setter Property="HorizontalAlignment" Value="Center" />
    </Style>

    <Style Selector="TextBlock.Center">
        <Setter Property="TextAlignment" Value="Center" />
    </Style>

    <Style Selector="TextBlock.Title">
        <Setter Property="FontSize" Value="25" />
        <Setter Property="FontWeight" Value="Bold" />
    </Style>

    <Style Selector="TextBlock.Subtitle">
        <Setter Property="FontSize" Value="18" />
        <Setter Property="FontWeight" Value="SemiLight" />
    </Style>

    <Style Selector="TextBlock.TitleStrong">
        <Setter Property="FontSize" Value="25" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{StaticResource Strong}" />
    </Style>

    <Style Selector="EnhancedButton">
        <Setter Property="Background" Value="{StaticResource Accent}" />
        <Setter Property="Foreground" Value="{StaticResource Overbackground}" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Padding" Value="24 12" />
        <Setter Property="BorderBrush" Value="{StaticResource Accent}" />
        <Setter Property="BorderThickness" Value="2" />
    </Style>

    <Style Selector="EnhancedButton.Primary">
        <Setter Property="Foreground" Value="{StaticResource Background}" />
        <Setter Property="Background" Value="{StaticResource Strong}" />
        <Setter Property="BorderBrush" Value="{StaticResource Strong}" />
        <Setter Property="BorderThickness" Value="2" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Padding" Value="24 12" />
    </Style>

    <Style Selector="EnhancedButton.Secondary">
        <Setter Property="Background" Value="{StaticResource Background}" />
        <Setter Property="Foreground" Value="{StaticResource Strong}" />
        <Setter Property="BorderBrush" Value="{StaticResource Strong}" />
        <Setter Property="BorderThickness" Value="2" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Padding" Value="24 12" />
    </Style>

    <Style Selector="StackPanel.HugeGap">
        <Setter Property="Spacing" Value="20" />
    </Style>

    <Design.PreviewWith>
        <StackPanel Spacing="20">
            <Border Classes="Regular" Width="200" Height="200">
                <TextBlock>HOLA</TextBlock>
            </Border>
            <EnhancedButton Content="Invest Now" />
            <EnhancedButton Content="Invest Now" Classes="Primary" />
            <EnhancedButton Content="Invest Now" Classes="Secondary" />
        </StackPanel>
    </Design.PreviewWith>

</Styles>