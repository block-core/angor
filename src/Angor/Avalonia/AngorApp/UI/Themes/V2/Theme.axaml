<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:FluentAvalonia.UI.Controls;assembly=FluentAvalonia">
    
    <FluentTheme />
    <StyleInclude Source="avares://Zafiro.Avalonia/Styles.axaml" />
    <StyleInclude Source="avares://Zafiro.Avalonia.Dialogs/Styles.axaml" />
    <StyleInclude Source="avares://AsyncImageLoader.Avalonia/AdvancedImage.axaml" />

    <StyleInclude Source="Controls/EnhancedButton.axaml" />
    <StyleInclude Source="Styles/ToggleButtons.axaml" />
    <StyleInclude Source="Controls/ListBox.axaml" />
    <StyleInclude Source="Controls/Wizard.axaml" />
    <StyleInclude Source="Controls/CalendarPicker.axaml" />
    <StyleInclude Source="Controls/NumericUpDown.axaml" />

    <StyleInclude Source="/UI/Shared/Styles/Styles.axaml" />
    <StyleInclude Source="/UI/Shared/Controls/Pane.axaml" />
    <StyleInclude Source="/UI/Shared/Controls/AmountControl.axaml" />
    <StyleInclude Source="/UI/Shared/Controls/List.axaml" />
    <StyleInclude Source="/UI/Shared/Controls/IconLabel.axaml" />
    <StyleInclude Source="/UI/Shared/Controls/ProjectCard.axaml" />
    <StyleInclude Source="/UI/Shared/Controls/Feerate/FeerateSelector.axaml" />
    <StyleInclude Source="/UI/Shared/Controls/ErrorSummary.axaml" />
    <StyleInclude Source="/UI/Sections/Wallet/CreateAndImport/Steps/SeedWordsGeneration/SeedWordList.axaml" />
    <StyleInclude Source="/UI/Shared/Controls/PageContainer.axaml" />
    <StyleInclude Source="/UI/Shared/Controls/ScrollableView.axaml" />
    <StyleInclude Source="/UI/Shared/Controls/Badge.axaml" />
    <StyleInclude Source="/UI/Shared/Styles/Cards.axaml" />
    <StyleInclude Source="/UI/Shared/Styles/OverlayBorder.axaml" />
    <StyleInclude Source="/UI/Shared/Styles/TextBlock.axaml" />
    <StyleInclude Source="/UI/Shared/Styles/ToggleButton.axaml" />
    <StyleInclude Source="/UI/Shared/Styles/FlyoutPresenter.axaml" />
    <StyleInclude Source="/UI/Shared/Styles/Button.axaml" />
    <StyleInclude Source="/UI/Shared/Styles/Automation.axaml" />
    <StyleInclude Source="/UI/Shared/Styles/SlimDataGrid.axaml" />
    <StyleInclude Source="/UI/Shared/Styles/HeaderedContainer.axaml" />
    <StyleInclude Source="/UI/Shared/Styles/EdgePanel.axaml" />
    <StyleInclude Source="/UI/Shared/Styles/Border.axaml" />
    <StyleInclude Source="Styles/Containers.axaml" />
    <StyleInclude Source="Styles/Buttons.axaml" />
    <StyleInclude Source="Styles/Typography.axaml" />
    <StyleInclude Source="Styles/Borders.axaml" />
    <StyleInclude Source="Controls/Frame.axaml" />
    <StyleInclude Source="Styles/CheckBox.axaml" />
    <StyleInclude Source="Styles/ComboBox.axaml" />
    <StyleInclude Source="Styles/ProgressBar.axaml" />
    <StyleInclude Source="Styles/ProgressRing.axaml" />
    <StyleInclude Source="Styles/Expander.axaml" />
    <StyleInclude Source="Styles/DialogControl.axaml" />
    <StyleInclude Source="Styles/DialogViewContainer.axaml" />
    
    <Style Selector=":is(UserControl)">
        <Setter Property="Foreground" Value="{DynamicResource TextMuted}" />
        <Setter Property="IconOptions.Fill" Value="{DynamicResource TextMuted}" />
    </Style>

    <Style Selector="Border.Panel">
        <Setter Property="CornerRadius" Value="20" />
        <Setter Property="Padding" Value="20" />
        <Setter Property="BorderBrush" Value="{DynamicResource Stroke}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Background" Value="{DynamicResource Surface}" />
    </Style>

    <Style Selector="OverlayBorder.Panel">
        <Setter Property="CornerRadius" Value="20" />
        <Setter Property="Padding" Value="20" />
        <Setter Property="BorderBrush" Value="{DynamicResource Stroke}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Background" Value="{DynamicResource Surface}" />
    </Style>

    <Style Selector="SectionStrip.Nav SectionStripGroupHeader">
        <Setter Property="Foreground" Value="{DynamicResource Brand}" />
        <Setter Property="FontFamily" Value="Sans Serif" />
        <Setter Property="FontWeight" Value="SemiLight" />
        <Setter Property="FontSize" Value="18" />
        <Setter Property="Margin" Value="10" />
    </Style>

    <Style Selector="SectionStrip.Nav SectionStripItem">
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Padding" Value="8" />
        <Setter Property="IconOptions.Fill" Value="{Binding $self.Foreground}" />
        <Setter Property="Margin" Value="10" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{DynamicResource TextMuted}" />
        <Setter Property="ClipToBounds" Value="False" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style Selector="SectionStrip.Nav SectionStripItem:pointerover">
        <Setter Property="Background" Value="{DynamicResource SurfaceHover}" />
    </Style>

    <Style Selector="SectionStrip.Nav SectionStripItem:selected">
        <Setter Property="Background" Value="{DynamicResource SurfaceSelected}" />
        <Setter Property="Foreground" Value="{DynamicResource Highlight}" />
    </Style>

    <Style Selector="SectionStrip.Nav SectionStripItem:selected Border">
        <Setter Property="BoxShadow" Value="{DynamicResource SectionShadow}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Stroke}" />
    </Style>

   

    <Style Selector="Border.Elevated">
        <Setter Property="Background" Value="{DynamicResource CardSurface}" />
        <Setter Property="BoxShadow" Value="{DynamicResource ItemShadow}" />
        <Setter Property="Transitions">
            <Transitions>
                <BoxShadowsTransition Property="BoxShadow" Duration="0:0:1" />
            </Transitions>
        </Setter>
    </Style>
    <Style Selector="Border.Elevated:pointerover">
        <Setter Property="BoxShadow" Value="{DynamicResource ItemShadowBig}" />
    </Style>
    <Style Selector="Border.Interactive">
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Transitions">
            <Transitions>
                <TransformOperationsTransition Property="RenderTransform" Duration="0:0:.125" />
            </Transitions>
        </Setter>
        <Setter Property="RenderTransform" Value="translate(0px, 0px)" />
    </Style>
    <Style Selector="Border.Interactive:pointerover">
        <Setter Property="RenderTransform" Value="translate(0px, -3px)" />
    </Style>

    <Style Selector=":is(Control).Padded">
        <Setter Property="Margin" Value="20 0" />
    </Style>
    
    <Styles.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="Resources/Colors.axaml" />
                <ResourceInclude Source="Resources/Icons.axaml" />
                <ResourceInclude Source="Controls/ErrorSummary.axaml" />
            </ResourceDictionary.MergedDictionaries>

            <ControlTheme x:Key="{x:Type TextBox}"
                          TargetType="TextBox"
                          BasedOn="{StaticResource {x:Type TextBox}}">
                <Setter Property="CornerRadius" Value="8" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="BorderBrush" Value="{DynamicResource SurfaceSubtle}" />
                <Setter Property="Background" Value="{DynamicResource Surface}" />
                <Setter Property="Foreground" Value="{DynamicResource TextStrong}" />
                <Setter Property="Padding" Value="14 12" />
                <Style Selector="^ /template/ Border#PART_BorderElement">
                    <Setter Property="Transitions">
                        <Transitions>
                            <BrushTransition Property="BorderBrush" Duration="0:0:0.2" />
                            <BrushTransition Property="Background" Duration="0:0:0.2" />
                        </Transitions>
                    </Setter>
                </Style>
            </ControlTheme>

        </ResourceDictionary>
    </Styles.Resources>
    
</Styles>