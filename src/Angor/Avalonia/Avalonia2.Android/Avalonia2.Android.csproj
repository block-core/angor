<Project Sdk="Microsoft.NET.Sdk">
    <PropertyGroup>
        <OutputType>Exe</OutputType>
        <TargetFramework>net9.0-android</TargetFramework>
        <SupportedOSPlatformVersion>21</SupportedOSPlatformVersion>
        <Nullable>enable</Nullable>
        <ApplicationId>io.Angor.Avalonia2</ApplicationId>
        <ApplicationVersion>1</ApplicationVersion>
        <ApplicationDisplayVersion>0.1.0</ApplicationDisplayVersion>
        <AndroidPackageFormat>apk</AndroidPackageFormat>
        <RootNamespace>Avalonia2.Android</RootNamespace>
    </PropertyGroup>
    <PropertyGroup Condition="'$(Configuration)'=='Release'">
        <RuntimeIdentifier>android-arm64</RuntimeIdentifier>
        <Optimize>true</Optimize>
        <PublishTrimmed>true</PublishTrimmed>
        <TrimMode>partial</TrimMode>
        <OptimizationPreference>Speed</OptimizationPreference>
        <PublishAot>false</PublishAot>
        <DebugSymbols>false</DebugSymbols>
        <DebugType>none</DebugType>
        <RunAOTCompilation>true</RunAOTCompilation>
        <AndroidEnableProfiledAot>true</AndroidEnableProfiledAot>
        <EnableAssemblyILStripping>true</EnableAssemblyILStripping>
        <NoWarn>$(NoWarn);IL2026;IL2111</NoWarn>
        <AspectInjectorEnabled>false</AspectInjectorEnabled>
    </PropertyGroup>
    <ItemGroup>
        <!-- Android app icon with day/night variants -->
        <AndroidResource Include="Resources\drawable\icon.png" />
        <AndroidResource Include="Resources\drawable-night\icon.png" />
    </ItemGroup>

    <ItemGroup>
        <PackageReference Include="Avalonia.Android" />
        <PackageReference Include="Xamarin.AndroidX.Core.SplashScreen" />
    </ItemGroup>

    <ItemGroup>
        <ProjectReference Include="..\Avalonia2\Avalonia2.csproj" />
    </ItemGroup>
</Project>
