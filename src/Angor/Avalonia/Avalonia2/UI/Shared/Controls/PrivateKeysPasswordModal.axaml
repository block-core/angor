<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="clr-namespace:Avalonia2.UI.Shared.Controls"
             mc:Ignorable="d" d:DesignWidth="500" d:DesignHeight="400"
             x:Class="Avalonia2.UI.Shared.Controls.PrivateKeysPasswordModal"
             x:DataType="controls:PrivateKeysPasswordModalViewModel">

    <!--
        Private Keys Password Step — Vue ManageFunds.vue lines 559-611
        Shell modal pattern: card content only, no backdrop (shell provides blur + backdrop).
        max-w-md (~448px), rounded-2xl, shadow-2xl
    -->

    <Panel>
        <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                MinWidth="400" MaxWidth="448"
                CornerRadius="16"
                Background="{DynamicResource RecoveryModalBg}"
                BorderBrush="{DynamicResource RecoveryModalBorder}"
                BorderThickness="1"
                BoxShadow="0 25 50 0 #40000000">
            <StackPanel>
                <!-- Header: title + close -->
                <Border Padding="24"
                        BorderBrush="{DynamicResource ModalHeaderBorder}"
                        BorderThickness="0,0,0,1">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Grid.Column="0"
                                   Text="View Private Keys"
                                   FontSize="20" FontWeight="Bold"
                                   Foreground="{DynamicResource TextStrong}"
                                   VerticalAlignment="Center" />
                        <!-- Close X — matches other modals: Path + Viewbox -->
                        <Button Name="CloseButton" Classes="ModalCloseBtn" Grid.Column="1"
                                VerticalAlignment="Center" />
                    </Grid>
                </Border>

                <!-- Body -->
                <StackPanel Margin="24">
                    <!-- Description -->
                    <TextBlock Text="Please enter your wallet password to view your NOSTR private keys."
                               FontSize="13"
                               Foreground="{DynamicResource TextMuted}"
                               TextWrapping="Wrap"
                               Margin="0,0,0,16" />

                    <!-- Password input -->
                    <TextBox Name="PasswordInput"
                             Text="{Binding Password, Mode=TwoWay}"
                             Watermark="Enter wallet password"
                             PasswordChar="*"
                             FontSize="14"
                             Padding="16,12"
                             CornerRadius="8"
                             Background="{DynamicResource ModalInputBg}"
                             BorderBrush="{DynamicResource StrokeSubtle}"
                             BorderThickness="1"
                             Foreground="{DynamicResource TextStrong}"
                             VerticalContentAlignment="Center" />
                    <!-- Password error -->
                    <TextBlock Text="{Binding PasswordError}"
                               FontSize="13"
                               Foreground="{DynamicResource ErrorFieldText}"
                               IsVisible="{Binding HasPasswordError}"
                               Margin="0,4,0,0" />

                    <Panel Height="20" /> <!-- spacer replacing Margin="0,0,0,24" -->

                    <!-- Buttons row -->
                    <Grid ColumnDefinitions="*,12,*">
                        <!-- Cancel -->
                        <Button Name="CancelButton" Grid.Column="0"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center"
                                VerticalContentAlignment="Center"
                                Height="48"
                                Background="Transparent"
                                BorderBrush="{DynamicResource StrokeSubtle}"
                                BorderThickness="2"
                                CornerRadius="8"
                                Foreground="{DynamicResource ModalCancelBtnText}"
                                FontSize="16" FontWeight="SemiBold"
                                Cursor="Hand">
                            Cancel
                        </Button>

                        <!-- View Keys (Red) -->
                        <Button Name="ViewKeysButton" Grid.Column="2"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center"
                                VerticalContentAlignment="Center"
                                Height="48"
                                Background="{DynamicResource RedBtnBg}"
                                BorderThickness="0"
                                CornerRadius="8"
                                Foreground="White"
                                FontSize="16" FontWeight="SemiBold"
                                Cursor="Hand">
                            View Keys
                        </Button>
                    </Grid>
                </StackPanel>
            </StackPanel>
        </Border>
    </Panel>
</UserControl>
