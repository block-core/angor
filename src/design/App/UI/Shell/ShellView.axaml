<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:shell="clr-namespace:App.UI.Shell"
             xmlns:i="https://github.com/projektanker/icons.avalonia"
             mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="650"
             x:Class="App.UI.Shell.ShellView"
             x:DataType="shell:ShellViewModel"
             Background="{DynamicResource AppBackground}"
             TopLevel.AutoSafeAreaPadding="False">

    <!-- Floating bar button template overrides — Avalonia's default Button template
         ContentPresenter needs explicit Background + CornerRadius to match the outer border.
         Cover all states (normal, pointerover, pressed) to prevent default chrome. -->
    <UserControl.Styles>
        <!-- Back button -->
        <Style Selector="Button#InvestorBackBtn /template/ ContentPresenter">
            <Setter Property="Background" Value="{StaticResource MobileBackBtnBg}" />
            <Setter Property="CornerRadius" Value="16" />
        </Style>
        <Style Selector="Button#InvestorBackBtn:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{StaticResource MobileBackBtnBg}" />
        </Style>
        <Style Selector="Button#InvestorBackBtn:pressed /template/ ContentPresenter">
            <Setter Property="Background" Value="{StaticResource MobileBackBtnBg}" />
        </Style>
        <!-- Invest CTA button -->
        <Style Selector="Button#InvestorCtaBtn /template/ ContentPresenter">
            <Setter Property="Background" Value="{StaticResource GreenGradient}" />
            <Setter Property="CornerRadius" Value="16" />
        </Style>
        <Style Selector="Button#InvestorCtaBtn:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{StaticResource GreenGradient}" />
        </Style>
        <Style Selector="Button#InvestorCtaBtn:pressed /template/ ContentPresenter">
            <Setter Property="Background" Value="{StaticResource GreenGradient}" />
        </Style>
        <!-- Share button -->
        <Style Selector="Button#InvestorShareBtn /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource MobileShareBtnBg}" />
            <Setter Property="CornerRadius" Value="16" />
        </Style>
        <Style Selector="Button#InvestorShareBtn:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource MobileShareBtnBg}" />
        </Style>
        <Style Selector="Button#InvestorShareBtn:pressed /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource MobileShareBtnBg}" />
        </Style>
    </UserControl.Styles>

    <!-- Outer Panel allows modal overlay to stack above entire shell -->
    <Panel>
        <!-- ═══════════════════════════════════════════════════════════ -->
        <!-- UNIFIED ADAPTIVE SHELL LAYOUT                               -->
        <!-- Single Grid with ONE ContentControl — avoids dual-parent    -->
        <!-- crash. Desktop: sidebar+header visible, tab bar hidden.     -->
        <!-- Compact: sidebar+header hidden, tab bar visible.            -->
        <!-- ═══════════════════════════════════════════════════════════ -->
        <Grid Name="ShellContent" ColumnDefinitions="208,*" RowDefinitions="42,*,0">
            <!-- Desktop layout: Column 0 = sidebar (208px), Column 1 = content
                 Row 0 = header (42px), Row 1 = content, Row 2 = tab bar (0 on desktop)
                 Compact layout: Column 0 = 0px, Column 1 = content full-width
                 Row 0 = 0px (header hidden), Row 1 = content, Row 2 = tab bar (Auto)
                 ColumnDefinitions/RowDefinitions set in code-behind via LayoutModeService -->

            <!-- ── DESKTOP HEADER ROW (Row 0) ── -->
            <!-- Vue: hidden lg:flex — logo + section name + balances + wallet switcher + settings -->

            <!-- Logo — centered within the sidebar column (Vue: w-52 = 208px, logo centered) -->
            <Svg Name="DesktopLogo" Path="/Assets/logo.svg" Width="32" Height="32"
                 Grid.Row="0" Grid.Column="0"
                 HorizontalAlignment="Center" VerticalAlignment="Center" />

            <!-- Top bar (Vue: hidden lg:flex header) -->
            <DockPanel Name="DesktopHeader" Grid.Row="0" Grid.Column="1">
                <TextBlock FontWeight="Bold" VerticalAlignment="Center" FontSize="20"
                           Text="{Binding SelectedSectionName}" />
                <!-- Profile tag — small branded badge, visible only for non-default profiles -->
                <Border IsVisible="{Binding ProfileName, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                        Background="{DynamicResource Brand}"
                        CornerRadius="4" Padding="8,2"
                        VerticalAlignment="Center" Margin="12,0,0,0">
                    <TextBlock Text="{Binding ProfileName}" FontSize="12" Foreground="White" />
                </Border>
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Right" Spacing="16" Orientation="Horizontal">
                    <TextBlock VerticalAlignment="Center"
                             AutomationProperties.AutomationId="ShellInvestedBalanceText">
                        <TextBlock.Inlines>
                            <Run Classes="Thin">Invested:</Run>
                            <Run Classes="Label" Text="{Binding InvestedBalanceDisplay}" />
                        </TextBlock.Inlines>
                    </TextBlock>
                    <TextBlock VerticalAlignment="Center"
                             AutomationProperties.AutomationId="ShellAvailableBalanceText">
                        <TextBlock.Inlines>
                            <Run Classes="Thin">Available:</Run>
                            <Run Classes="Label" Text="{Binding AvailableBalanceDisplay}" />
                        </TextBlock.Inlines>
                    </TextBlock>
                    <!-- Wallet Switcher Button
                         Vue: .wallet-selector-header — pl-9 pr-10 py-2.5, text-sm, border rounded-md
                         Contains: wallet icon (absolute left), wallet name, up/down chevron (absolute right)
                         Height matches Widget buttons (42px), CornerRadius 10 -->
                    <Button Name="WalletSwitcherButton"
                            Background="{DynamicResource WalletSwitcherBg}"
                            BorderBrush="{DynamicResource StrokeSubtle}"
                            BorderThickness="1" CornerRadius="10"
                            Height="42"
                            Padding="36,0,40,0"
                            Cursor="Hand" VerticalAlignment="Center"
                            Click="OnWalletSwitcherClick">
                        <Button.Styles>
                            <Style Selector="Button#WalletSwitcherButton:pointerover /template/ ContentPresenter">
                                <Setter Property="Background" Value="{DynamicResource WalletSwitcherHoverBg}" />
                            </Style>
                        </Button.Styles>
                        <Panel>
                            <!-- Wallet icon — same NavIconWallet as the Funds sidebar item (filled) -->
                            <Viewbox Width="16" Height="16"
                                     HorizontalAlignment="Left" VerticalAlignment="Center"
                                     Margin="-24,0,0,0">
                                <Path Data="{StaticResource NavIconWallet}"
                                      Fill="{DynamicResource WalletSwitcherFg}"
                                      Stretch="Uniform" />
                            </Viewbox>
                            <!-- Wallet name -->
                            <TextBlock Text="{Binding SelectedWalletName}"
                                       FontSize="14"
                                       Foreground="{DynamicResource WalletSwitcherFg}"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center" />
                            <!-- Up/down chevron icon (positioned right) -->
                            <i:Icon Value="fa-solid fa-sort" FontSize="13"
                                    Foreground="{DynamicResource WalletSwitcherFg}"
                                    HorizontalAlignment="Right" VerticalAlignment="Center"
                                    Margin="0,0,-26,0" />
                        </Panel>
                    </Button>
                    <ToggleButton Classes="Widget" IsChecked="{Binding IsDarkThemeEnabled, Mode=TwoWay}">
                        <ToggleButton.Content>
                            <i:Icon Value="fa-solid fa-sun" FontSize="16" Foreground="{DynamicResource TextMuted}" />
                        </ToggleButton.Content>
                    </ToggleButton>
                    <Button Classes="Widget" Name="SettingsButton" Click="OnSettingsClick"
                            AutomationProperties.AutomationId="SettingsButton">
                        <Panel Width="24" Height="24">
                            <Path Data="{StaticResource NavIconSettings}"
                                  Stroke="{DynamicResource TextMuted}"
                                  StrokeThickness="2"
                                  StrokeLineCap="Round"
                                  StrokeJoin="Round" />
                        </Panel>
                    </Button>
                </StackPanel>
            </DockPanel>

            <!-- ── SIDEBAR (Row 1, Column 0) ── -->
            <!-- Vue: w-52 = 208px, px-6 = 24px horizontal padding, hidden below lg (1024px) -->
            <Border Name="DesktopSidebar" Grid.Row="1" Grid.Column="0" Padding="24,8" ClipToBounds="False">
                <ListBox ItemsSource="{Binding NavEntries}"
                         SelectedItem="{Binding SelectedNavItem}"
                         Classes="Nav"
                         ContainerPrepared="OnNavContainerPreparing">
                    <ListBox.DataTemplates>
                        <!-- Nav item: icon + label -->
                        <DataTemplate DataType="shell:NavItem">
                            <DockPanel HorizontalSpacing="10">
                                <Viewbox Width="20" Height="20" DockPanel.Dock="Left">
                                    <Panel Width="24" Height="24">
                                        <!-- Stroke-based icon (Heroicons outline) -->
                                        <Path Data="{Binding Icon, Converter={x:Static shell:NavIconConverter.Instance}}"
                                              Stroke="{Binding $parent[ListBoxItem].Foreground}"
                                              StrokeThickness="2"
                                              StrokeLineCap="Round"
                                              StrokeJoin="Round"
                                              IsVisible="{Binding IconIsFilled, Converter={x:Static BoolConverters.Not}}" />
                                        <!-- Fill-based icon (wallet) — uses different viewBox via Stretch -->
                                        <Path Data="{Binding Icon, Converter={x:Static shell:NavIconConverter.Instance}}"
                                              Fill="{Binding $parent[ListBoxItem].Foreground}"
                                              Stretch="Uniform"
                                              IsVisible="{Binding IconIsFilled}" />
                                    </Panel>
                                </Viewbox>
                                <TextBlock Text="{Binding Label}"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis" />
                            </DockPanel>
                        </DataTemplate>
                        <!-- Group header: gradient divider line + uppercase label
                             Vue: px-3 mt-8 mb-6 wrapper, h-px mb-4 divider, text-sm font-extrabold tracking-widest label -->
                        <DataTemplate DataType="shell:NavGroupHeader">
                            <StackPanel Margin="12,0,12,0">
                                <!-- Gradient divider: transparent → gray → transparent (1px height, 16px gap to label) -->
                                <Rectangle Height="1" Margin="0,0,0,16"
                                           Fill="{DynamicResource NavGroupDivider}" />
                                <!-- Group label -->
                                <TextBlock Text="{Binding Title}"
                                           FontFamily="{StaticResource FontFamilySans}"
                                           FontSize="14"
                                           FontWeight="ExtraBold"
                                           Foreground="{DynamicResource Brand}"
                                           LetterSpacing="1.4" />
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.DataTemplates>
                </ListBox>
            </Border>

            <!-- ── MAIN CONTENT AREA (Row 1, Column 1) — SINGLE ContentControl ── -->
            <!-- This is the ONLY ContentControl binding CurrentSectionContent.
                 On desktop: sits in column 1, right of sidebar.
                 On compact: column 0 collapses to 0px, so this fills full width. -->
            <Border Name="ContentBorder" Grid.Row="1" Grid.Column="1" Classes="Panel" Padding="0" ClipToBounds="True">
                <ContentControl Content="{Binding CurrentSectionContent}" />
            </Border>

            <!-- ── COMPACT-ONLY: Floating sub-tab panels (Row 1, above tab bar) ── -->
            <!-- Vue: fixed bottom-20, z-40, rounded-2xl pill with two buttons -->

            <!-- Investor sub-tabs: "Find Projects" / "Funded"
                 Vue: shown when mobileActiveTab === 'investor' && not in detail views -->
            <Border Name="InvestorSubTabs" Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                    IsVisible="False"
                    VerticalAlignment="Bottom"
                    HorizontalAlignment="Stretch"
                    Margin="16,0,16,12"
                    ZIndex="40"
                    Background="{DynamicResource SubTabPanelBg}"
                    BorderBrush="{DynamicResource SubTabPanelBorder}"
                    BorderThickness="1"
                    CornerRadius="16"
                    ClipToBounds="True">
                <Grid ColumnDefinitions="*,*">
                    <Button Name="InvestorSubTabFind" Grid.Column="0"
                            Classes="SubTab SubTabActive"
                            Content="Find Projects"
                            Click="OnInvestorSubTabFind" />
                    <Button Name="InvestorSubTabFunded" Grid.Column="1"
                            Classes="SubTab"
                            Content="Funded"
                            Click="OnInvestorSubTabFunded" />
                </Grid>
            </Border>

            <!-- Founder sub-tabs: "My Projects" / "Funders"
                 Vue: shown when mobileActiveTab === 'founder' && not in detail views -->
            <Border Name="FounderSubTabs" Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                    IsVisible="False"
                    VerticalAlignment="Bottom"
                    HorizontalAlignment="Stretch"
                    Margin="16,0,16,12"
                    ZIndex="40"
                    Background="{DynamicResource SubTabPanelBg}"
                    BorderBrush="{DynamicResource SubTabPanelBorder}"
                    BorderThickness="1"
                    CornerRadius="16"
                    ClipToBounds="True">
                <Grid ColumnDefinitions="*,*">
                    <Button Name="FounderSubTabMyProjects" Grid.Column="0"
                            Classes="SubTab SubTabActive"
                            Content="My Projects"
                            Click="OnFounderSubTabMyProjects" />
                    <Button Name="FounderSubTabFunders" Grid.Column="1"
                            Classes="SubTab"
                            Content="Funders"
                            Click="OnFounderSubTabFunders" />
                </Grid>
            </Border>

            <!-- ── COMPACT-ONLY: Floating back button bars (Row 1, above tab bar) ── -->
            <!-- These replace sub-tabs when detail views are open. Visibility managed in code-behind. -->

            <!-- Investor back bar: Back + green Invest CTA + Share button
                 Vue (line 6203): v-if="(showProjectDetail || showInvestPage) && mobileActiveTab === 'investor'"
                 Height 52px, rounded-2xl, gap-2, fixed bottom-20 -->
            <Border Name="InvestorBackBar" Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                    IsVisible="False"
                    VerticalAlignment="Bottom"
                    HorizontalAlignment="Stretch"
                    Margin="16,0,16,12"
                    ZIndex="40">
                <!-- Vue: flex gap-2 — Back (flex-1) + CTA (flex-1) + Share (52px fixed)
                     Use Grid: col 0 = *, col 1 = *, col 2 = 52px -->
                <Grid ColumnDefinitions="*,*,52" ColumnSpacing="8">
                    <!-- Back button — Vue line 6207: ALWAYS bg-[#1a1a1a] border-[#333] text-white, NOT theme-aware.
                         NOTE: Classes="Secondary Light" segfaults Avalonia Android at render time.
                         Use inline brushes until the root cause is resolved. The Secondary.Light
                         preset exists in Buttons.axaml for future use on desktop-only buttons. -->
                    <Button Name="InvestorBackBtn" Grid.Column="0"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"
                            VerticalContentAlignment="Center"
                            Height="52"
                            CornerRadius="16"
                            Background="{StaticResource MobileBackBtnBg}"
                            BorderBrush="{StaticResource MobileBackBtnBorder}"
                            BorderThickness="1"
                            Foreground="{StaticResource MobileBackBtnText}"
                            FontWeight="SemiBold" FontSize="14"
                            Content="Back"
                            Cursor="Hand"
                            Click="OnInvestorBackClick" />

                    <!-- Invest CTA — Vue: flex-1 bg-gradient green, rounded-2xl, 52px height, Bitcoin icon + text -->
                    <Button Name="InvestorCtaBtn" Grid.Column="1"
                            HorizontalAlignment="Stretch"
                            Height="52"
                            CornerRadius="16"
                            Background="{StaticResource GreenGradient}"
                            BorderThickness="0"
                            Foreground="White"
                            FontWeight="SemiBold" FontSize="14"
                            Cursor="Hand"
                            Click="OnInvestorCtaClick">
                        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                            <i:Icon Value="fa-solid fa-bitcoin-sign" FontSize="16" Foreground="White" />
                            <TextBlock Name="InvestorCtaText" Text="Invest" FontWeight="SemiBold" FontSize="14"
                                       Foreground="White" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <!-- Share button — Vue: 52x52, rounded-2xl, theme-aware (light=white, dark=#1a1a1a) -->
                    <Button Name="InvestorShareBtn" Grid.Column="2"
                            Width="52" MinWidth="52" Height="52"
                            CornerRadius="16"
                            Background="{DynamicResource MobileShareBtnBg}"
                            BorderBrush="{DynamicResource MobileShareBtnBorder}"
                            BorderThickness="1"
                            Cursor="Hand"
                            Padding="0"
                            Click="OnInvestorShareClick">
                        <i:Icon Value="fa-solid fa-share-nodes" FontSize="16"
                                Foreground="{DynamicResource MobileShareBtnText}" />
                    </Button>
                </Grid>
            </Border>

            <!-- Investment detail back button: "Back to Investments"
                 Vue (line 6234): v-if="showInvestmentDetail && currentPage === 'investments'"
                 Full-width green button, rounded-2xl, 52px height -->
            <Border Name="InvestmentDetailBackBar" Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                    IsVisible="False"
                    VerticalAlignment="Bottom"
                    HorizontalAlignment="Stretch"
                    Margin="16,0,16,12"
                    ZIndex="40"
                    CornerRadius="16">
                <Button Name="InvestmentDetailBackBtn"
                        HorizontalAlignment="Stretch"
                        Height="52"
                        CornerRadius="16"
                        Background="{StaticResource PrimaryGreenBrush}"
                        BorderThickness="0"
                        Foreground="White"
                        FontWeight="SemiBold" FontSize="14"
                        Cursor="Hand"
                        Click="OnInvestmentDetailBackClick">
                    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                        <i:Icon Value="fa-solid fa-chevron-left" FontSize="14" Foreground="White" />
                        <TextBlock Text="Back to Investments" FontWeight="SemiBold" FontSize="14"
                                   Foreground="White" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </Border>

            <!-- Manage funds back button: "Back to My Projects"
                 Vue (line 6247): v-if="showManageFunds && selectedManageFundsProject && currentPage === 'my-projects' && !isCreatingProject"
                 Full-width green button, rounded-2xl, 52px height -->
            <Border Name="ManageFundsBackBar" Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                    IsVisible="False"
                    VerticalAlignment="Bottom"
                    HorizontalAlignment="Stretch"
                    Margin="16,0,16,12"
                    ZIndex="40"
                    CornerRadius="16">
                <Button Name="ManageFundsBackBtn"
                        HorizontalAlignment="Stretch"
                        Height="52"
                        CornerRadius="16"
                        Background="{StaticResource PrimaryGreenBrush}"
                        BorderThickness="0"
                        Foreground="White"
                        FontWeight="SemiBold" FontSize="14"
                        Cursor="Hand"
                        Click="OnManageFundsBackClick">
                    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                        <i:Icon Value="fa-solid fa-chevron-left" FontSize="14" Foreground="White" />
                        <TextBlock Text="Back to My Projects" FontWeight="SemiBold" FontSize="14"
                                   Foreground="White" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </Border>

            <!-- ── COMPACT-ONLY: Bottom Tab Bar (Row 2) ── -->
            <!-- Material Design 3 bottom navigation bar
                 Height: 80dp, active pill indicator (64x32dp, 16dp radius)
                 Icon: 24dp, label: 12px medium, gap: 4dp
                 Safe area: bottom padding for Android gesture nav bar -->
            <Border Name="BottomTabBar" Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                    ZIndex="50"
                    IsVisible="False"
                    Background="{DynamicResource TabBarBackground}"
                    BorderBrush="{DynamicResource TabBarBorder}"
                    BorderThickness="0,1,0,0">
                <!-- MD3 compact: 64dp height + safe area padding at bottom
                     Compact variant better suited for phones; icons vertically
                     centered; safe-area padding added via code-behind for Android. -->
                <!-- Vue-style tab bar: color-only active state, no pill indicator.
                     Active = brand green icon+label, Inactive = muted gray.
                     Vue ref: App.vue lines 6526-6584 -->
                <Grid Name="TabBarGrid" Height="64"
                      ColumnDefinitions="*,*,*,*,*"
                      HorizontalAlignment="Stretch">

                    <!-- Home tab — NavIconHome (Heroicons outline, stroke) -->
                    <Button Name="TabHome" Grid.Column="0" Classes="TabBarItem TabBarItemActive"
                            Click="OnTabHome">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="4">
                            <Viewbox Width="22" Height="22" HorizontalAlignment="Center">
                                <Panel Width="24" Height="24">
                                    <Path Classes="TabIconStroke" Data="{StaticResource NavIconHome}"
                                          StrokeThickness="2" StrokeLineCap="Round" StrokeJoin="Round" />
                                </Panel>
                            </Viewbox>
                            <TextBlock Text="Home" Classes="TabBarLabel"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <!-- Investor tab — NavIconTrendUp (Heroicons outline, stroke) -->
                    <Button Name="TabInvestor" Grid.Column="1" Classes="TabBarItem"
                            Click="OnTabInvestor">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="4">
                            <Viewbox Width="22" Height="22" HorizontalAlignment="Center">
                                <Panel Width="24" Height="24">
                                    <Path Classes="TabIconStroke" Data="{StaticResource NavIconTrendUp}"
                                          StrokeThickness="2" StrokeLineCap="Round" StrokeJoin="Round" />
                                </Panel>
                            </Viewbox>
                            <TextBlock Text="Investor" Classes="TabBarLabel"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <!-- Founder tab — NavIconDocument (Heroicons outline, stroke) -->
                    <Button Name="TabFounder" Grid.Column="2" Classes="TabBarItem"
                            Click="OnTabFounder">
                        <Panel>
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="4">
                                <Viewbox Width="22" Height="22" HorizontalAlignment="Center">
                                    <Panel Width="24" Height="24">
                                        <Path Classes="TabIconStroke" Data="{StaticResource NavIconDocument}"
                                              StrokeThickness="2" StrokeLineCap="Round" StrokeJoin="Round" />
                                    </Panel>
                                </Viewbox>
                                <TextBlock Text="Founder" Classes="TabBarLabel"
                                           HorizontalAlignment="Center" />
                            </StackPanel>
                            <!-- Notification badge (Vue: absolute top-1 right-1, w-4 h-4, bg Bitcoin orange) -->
                            <Border Name="FounderBadge"
                                    IsVisible="False"
                                    Width="16" Height="16"
                                    CornerRadius="8"
                                    Background="#F7931A"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Top"
                                    Margin="0,8,8,0">
                                <TextBlock Name="FounderBadgeText"
                                           Text="0"
                                           FontSize="10" FontWeight="Bold"
                                           Foreground="White"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Border>
                        </Panel>
                    </Button>

                    <!-- Funds tab — NavIconWallet (fill-based, non-standard viewBox) -->
                    <Button Name="TabFunds" Grid.Column="3" Classes="TabBarItem"
                            Click="OnTabFunds">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="4">
                            <Viewbox Width="22" Height="22" HorizontalAlignment="Center">
                                <Panel Width="24" Height="24">
                                    <Path Classes="TabIconFill" Data="{StaticResource NavIconWallet}"
                                          Stretch="Uniform" />
                                </Panel>
                            </Viewbox>
                            <TextBlock Text="Funds" Classes="TabBarLabel"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <!-- Settings tab — NavIconSettings (Heroicons outline, stroke) -->
                    <Button Name="TabSettings" Grid.Column="4" Classes="TabBarItem"
                            Click="OnTabSettings">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="4">
                            <Viewbox Width="22" Height="22" HorizontalAlignment="Center">
                                <Panel Width="24" Height="24">
                                    <Path Classes="TabIconStroke" Data="{StaticResource NavIconSettings}"
                                          StrokeThickness="2" StrokeLineCap="Round" StrokeJoin="Round" />
                                </Panel>
                            </Viewbox>
                            <TextBlock Text="Settings" Classes="TabBarLabel"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>

            <!-- App-wide crosshatch texture overlay
                 PERF: Hidden on mobile — DrawingBrush with TileMode="Tile" is expensive on mobile GPU -->
            <Border Name="TextureOverlay" Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="0" Grid.RowSpan="3"
                    Background="{DynamicResource AppTextureBrush}"
                    IsHitTestVisible="False" />
        </Grid>

        <!-- ═══════════════════════════════════════════════════════════ -->
        <!-- SHELL-LEVEL MODAL OVERLAY                                   -->
        <!-- Renders above the entire app (sidebar + top bar + content)  -->
        <!-- Any section can push content here via ShellViewModel         -->
        <!-- ═══════════════════════════════════════════════════════════ -->
        <Panel Name="ModalOverlay" IsVisible="False" ZIndex="1000"
               AutomationProperties.AutomationId="ModalOverlay">
            <Border Name="ShellModalBackdrop"
                    Background="{DynamicResource ModalBackdrop}"
                    HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />
        </Panel>

        <!-- ═══════════════════════════════════════════════════════════ -->
        <!-- TOAST NOTIFICATION                                          -->
        <!-- Vue: .copy-toast / .save-toast — fixed top-right, green bg, -->
        <!-- white text, 8px radius, checkmark icon, fade in/out 0.3s    -->
        <!-- ZIndex 2000 = above modals (1000)                           -->
        <!-- ═══════════════════════════════════════════════════════════ -->
        <Border Name="ToastOverlay"
                ZIndex="2000"
                IsHitTestVisible="False"
                IsVisible="False"
                Opacity="0"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="0,24,56,0"
                Background="{StaticResource ToastBackground}"
                BoxShadow="{StaticResource ToastShadow}"
                CornerRadius="8"
                Padding="16,8">
            <StackPanel Name="ToastContent" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center"
                        HorizontalAlignment="Left">
                <!-- Checkmark icon — fa-solid fa-check, white -->
                <i:Icon Value="fa-solid fa-check"
                        FontSize="14"
                        Foreground="White"
                        VerticalAlignment="Center" />
                <TextBlock Name="ToastText"
                           Text="{Binding ToastMessage}"
                           FontSize="14" FontWeight="Medium"
                           Foreground="White"
                           VerticalAlignment="Center" />
            </StackPanel>
        </Border>
    </Panel>
</UserControl>
