<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:home="clr-namespace:App.UI.Sections.Home"
              xmlns:controls="clr-namespace:App.UI.Shared.Controls"
              xmlns:i="https://github.com/projektanker/icons.avalonia"
              mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="App.UI.Sections.Home.HomeView"
             x:DataType="home:HomeViewModel">
    <Design.DataContext>
        <home:HomeViewModel />
    </Design.DataContext>

    <!--
        Home page: two equal-width cards side by side.
        Left  — "Fund Projects"  (Bitcoin icon, search button)
        Right — "Get Funded"     (Lightning icon, launch button)
        
        Matches Vue prototype at angor.tx1138.com/app.html (desktop layout)
        and legacy AngorApp HomeSectionView.
    -->
    <controls:ScrollableView ContentPadding="24,24,24,24">
        <Grid ColumnDefinitions="*,24,*" RowDefinitions="*" ClipToBounds="False">

            <!-- ═══ Fund Projects card (left) ═══ -->
            <Grid Grid.Column="0" MinHeight="480" ClipToBounds="False">
                <!-- Card background -->
                <Border Classes="Panel" ClipToBounds="False" />
                <!-- Tiled logo watermark overlay (matches Vue invest-column ::before) -->
                <Border CornerRadius="12" Background="{DynamicResource TiledLogoBrush}" IsHitTestVisible="False" />
                <!-- Content -->
                <StackPanel Spacing="0" VerticalAlignment="Center" Margin="48">
                    <!-- Bitcoin logo (80x80) — Vue: w-24 h-24 mb-8, fill=currentColor
                         Uses bitcoin.svg path data colored Brand green. -->
                    <Viewbox Width="80" Height="80"
                             Margin="0,0,0,32"
                             HorizontalAlignment="Center">
                        <Path Fill="{DynamicResource Brand}"
                              Data="M3.83416 97.05C20.924 28.4706 90.384 -13.2655 158.951 3.83032C227.534 20.9263 269.267 90.3898 252.169 158.965C235.071 227.536 165.612 269.268 97.0246 252.168C28.4654 235.072 -13.2715 165.617 3.83416 97.05ZM116.988 67.6653C113.932 66.9693 110.932 66.2808 108.02 65.5569L108.036 65.4856L88.6662 60.6497L84.9299 75.6497C85.0077 75.6675 95.3352 78.0343 95.131 78.1848C100.819 79.6048 101.847 83.3689 101.675 86.3528L95.1222 112.637C95.5143 112.737 96.0231 112.881 96.5832 113.105C96.1152 112.989 95.6148 112.861 95.0988 112.737L85.9133 149.557C85.2171 151.285 83.4528 153.877 79.4767 152.893C79.6128 153.096 69.2856 150.35 69.2677 150.345L62.2951 166.42L80.5734 170.977C83.9736 171.829 87.3059 172.721 90.5861 173.561L84.7736 196.896L98.8029 200.396L104.56 177.308C108.392 178.348 112.113 179.308 115.753 180.212L110.016 203.192L124.062 206.692L129.874 183.401C153.825 187.933 171.834 186.104 179.415 164.445C185.524 147.005 179.111 136.945 166.51 130.385C175.687 128.269 182.6 122.233 184.445 109.765C186.993 92.7331 174.023 83.5769 156.289 77.469L162.042 54.3977L147.996 50.8977L142.396 73.3616C138.703 72.4416 134.911 71.5731 131.143 70.7131L136.783 48.1018L122.745 44.6018L116.988 67.6653ZM116.837 129.492C126.358 131.868 156.889 136.573 152.353 154.761C148.012 172.2 118.645 162.772 109.124 160.408L116.837 129.492ZM127.358 87.301C135.286 89.277 160.822 92.9651 156.697 109.513C152.737 125.377 128.294 117.317 120.365 115.341L127.358 87.301Z"
                              Width="256" Height="256"
                              Stretch="Uniform" />
                    </Viewbox>
                    <!-- Title — Vue: text-3xl font-bold mb-4 tracking-tight -->
                    <TextBlock Classes="Title Strong"
                               Margin="0,0,0,16"
                               TextAlignment="Center"
                               HorizontalAlignment="Center"
                               Text="Fund Projects" />
                    <!-- Description — Vue: font-size 20px, leading-relaxed (1.625), normal weight, mb-8 -->
                    <TextBlock FontSize="20"
                               LineHeight="32"
                               FontWeight="Normal"
                               Margin="0,0,0,32"
                               Foreground="{DynamicResource TextMuted}"
                               TextAlignment="Center"
                               HorizontalAlignment="Center"
                               Text="Discover and fund innovative Bitcoin projects on the Angor platform." />
                    <!-- Action button — Vue: px-8 py-3 text-base btn-primary -->
                    <Border HorizontalAlignment="Center" Classes="ButtonShadow">
                        <Button Content="Find Projects"
                                Classes="Primary" />
                    </Border>
                </StackPanel>
            </Grid>

            <!-- ═══ Get Funded card (right) ═══ -->
            <Grid Grid.Column="2" MinHeight="480" ClipToBounds="False">
                <!-- Card background -->
                <Border Classes="Panel" ClipToBounds="False" />
                <!-- Content -->
                <StackPanel Spacing="0" VerticalAlignment="Center" Margin="48">
                    <!-- Lightning bolt outline (stroked SVG path, 80x80) — Vue: w-24 h-24 mb-8, fill=none stroke=currentColor stroke-width=1.5 -->
                    <Viewbox Width="80" Height="80"
                             Margin="0,0,0,32"
                             HorizontalAlignment="Center">
                        <Path Data="{StaticResource LightningBoltHero}"
                              Stroke="{DynamicResource Brand}"
                              StrokeThickness="1.5"
                              StrokeLineCap="Round"
                              StrokeJoin="Round"
                              Fill="Transparent"
                              Width="24" Height="24"
                              Stretch="Uniform" />
                    </Viewbox>
                    <!-- Title — Vue: text-3xl font-bold mb-4 tracking-tight -->
                    <TextBlock Classes="Title Strong"
                               Margin="0,0,0,16"
                               TextAlignment="Center"
                               HorizontalAlignment="Center"
                               Text="Get Funded" />
                    <!-- Description — Vue: font-size 20px, leading-relaxed (1.625), normal weight, mb-8 -->
                    <TextBlock FontSize="20"
                               LineHeight="32"
                               FontWeight="Normal"
                               Margin="0,0,0,32"
                               Foreground="{DynamicResource TextMuted}"
                               TextAlignment="Center"
                               HorizontalAlignment="Center"
                               Text="Create and launch your own projects to raise funding." />
                    <!-- Action button — Vue: px-8 py-3 text-base btn-primary -->
                    <Border HorizontalAlignment="Center" Classes="ButtonShadow">
                        <Button Content="Launch a Project"
                                Classes="Primary" />
                    </Border>
                </StackPanel>
            </Grid>

        </Grid>
    </controls:ScrollableView>
</UserControl>
