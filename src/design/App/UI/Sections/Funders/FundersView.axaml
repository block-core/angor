<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:funders="clr-namespace:App.UI.Sections.Funders"
             xmlns:controls="clr-namespace:App.UI.Shared.Controls"
             xmlns:i="https://github.com/projektanker/icons.avalonia"
             mc:Ignorable="d" d:DesignWidth="1100" d:DesignHeight="800"
             x:Class="App.UI.Sections.Funders.FundersView"
             x:DataType="funders:FundersViewModel">
    <Design.DataContext>
        <funders:FundersViewModel />
    </Design.DataContext>

    <!-- Vue: signature card hover — subtle shadow transition -->
    <UserControl.Styles>
        <!-- Mobile: strip BoxShadow + transitions that waste GPU on touch devices -->
        <Style Selector="funders|FundersView.Mobile Border.SignatureCard">
            <Setter Property="Transitions" Value="{x:Null}" />
            <Setter Property="BoxShadow" Value="0 0 0 0 Transparent" />
            <Setter Property="Padding" Value="16" />
        </Style>

        <Style Selector="funders|FundersView.Mobile DockPanel.FundersHeader">
            <Setter Property="IsVisible" Value="False" />
        </Style>

        <!-- Empty-state auto-approve card: desktop margin lives here (not inline)
             so the Mobile override below can win — inline properties beat styles. -->
        <Style Selector="Border.EmptyAutoApproveCard">
            <Setter Property="Margin" Value="24" />
        </Style>
        <!-- Mobile: clear the bottom tab bar (same 96px clearance the list uses) -->
        <Style Selector="funders|FundersView.Mobile Border.EmptyAutoApproveCard">
            <Setter Property="Margin" Value="16,24,16,96" />
        </Style>

        <Style Selector="Border.FilterTabsOuter">
            <Setter Property="Background" Value="{DynamicResource FundersFilterRailBg}" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="4" />
            <Setter Property="Margin" Value="0,0,0,24" />
        </Style>

        <Style Selector="funders|FundersView.Mobile Border.FilterTabsOuter">
            <Setter Property="Background" Value="{DynamicResource FundersFilterRailBg}" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="4" />
            <Setter Property="Margin" Value="0,0,0,16" />
        </Style>

        <Style Selector="Border.SignatureCard">
            <Setter Property="Opacity" Value="1" />
        </Style>
        <Style Selector="Border.SignatureCard:pointerover">
            <Setter Property="BoxShadow" Value="{DynamicResource ItemShadowHover}" />
        </Style>

        <!-- Filter tab styles — CSS class toggling (no code-behind color logic) -->
        <Style Selector="Border.FilterTab">
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
        <Style Selector="funders|FundersView.Mobile Border.FilterTab">
            <Setter Property="Height" Value="36" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
        </Style>
        <Style Selector="Border.FilterTab:pointerover">
            <Setter Property="Opacity" Value="0.8" />
        </Style>
        <!-- Active tab: green bottom border -->
        <Style Selector="Border.FilterTab.FilterTabActive">
            <Setter Property="Background" Value="{DynamicResource PrimaryGreenBrush}" />
            <Setter Property="BorderBrush" Value="Transparent" />
        </Style>
        <Style Selector="funders|FundersView.Mobile Border.FilterTab.FilterTabActive">
            <Setter Property="Background" Value="{DynamicResource PrimaryGreenBrush}" />
            <Setter Property="BorderBrush" Value="Transparent" />
        </Style>
        <!-- Inactive tab text: muted -->
        <Style Selector="Border.FilterTab TextBlock.TabLabel">
            <Setter Property="Foreground" Value="{DynamicResource TextMuted}" />
        </Style>
        <!-- Active tab text: strong -->
        <Style Selector="Border.FilterTab.FilterTabActive TextBlock.TabLabel">
            <Setter Property="Foreground" Value="White" />
        </Style>
        <Style Selector="funders|FundersView.Mobile Border.FilterTab.FilterTabActive TextBlock.TabLabel">
            <Setter Property="Foreground" Value="White" />
        </Style>

        <Style Selector="StackPanel.MobileSignatureLayout">
            <Setter Property="IsVisible" Value="False" />
        </Style>
        <Style Selector="StackPanel.MobileSignatureActions">
            <Setter Property="IsVisible" Value="False" />
        </Style>
        <Style Selector="funders|FundersView.Mobile DockPanel.DesktopSignatureLayout">
            <Setter Property="IsVisible" Value="False" />
        </Style>
        <Style Selector="funders|FundersView.Mobile StackPanel.MobileSignatureLayout">
            <Setter Property="IsVisible" Value="True" />
        </Style>
        <Style Selector="funders|FundersView.Mobile StackPanel.MobileSignatureActions">
            <Setter Property="IsVisible" Value="True" />
        </Style>

        <Style Selector="funders|FundersView.Mobile Button.FundersAction">
            <Setter Property="Height" Value="52" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
        </Style>
        <Style Selector="funders|FundersView.Mobile Border.FundersAction">
            <Setter Property="Height" Value="52" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
        </Style>
        <Style Selector="funders|FundersView.Mobile Button.FundersAction.IconOnly">
            <Setter Property="Width" Value="52" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
        </Style>

        <Style Selector="Border.SignatureStatusPill">
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="10,4" />
            <Setter Property="VerticalAlignment" Value="Top" />
        </Style>

        <Style Selector="Button.FundersAction">
            <Setter Property="Height" Value="44" />
            <Setter Property="Padding" Value="16,0" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style Selector="Button.FundersAction.IconOnly">
            <Setter Property="Width" Value="44" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
        </Style>
    </UserControl.Styles>

    <Panel AutomationProperties.AutomationId="FundersRootPanel">
        <!-- ═══════════════════════════════════════════════════════ -->
        <!-- LOADING STATE: busy with no data yet                    -->
        <!-- ═══════════════════════════════════════════════════════ -->
        <StackPanel IsVisible="{Binding ShowInitialLoading}"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="16">
            <i:Icon Value="fa-solid fa-spinner"
                    FontSize="32"
                    Foreground="{DynamicResource TextMutedBrush}"
                    HorizontalAlignment="Center"
                    RenderTransformOrigin="50%,50%">
                <i:Icon.RenderTransform>
                    <RotateTransform />
                </i:Icon.RenderTransform>
                <i:Icon.Styles>
                    <Style Selector="i|Icon[IsVisible=True]">
                        <Style.Animations>
                            <Animation Duration="0:0:1" IterationCount="INFINITE">
                                <KeyFrame Cue="0%">
                                    <Setter Property="RotateTransform.Angle" Value="0" />
                                </KeyFrame>
                                <KeyFrame Cue="100%">
                                    <Setter Property="RotateTransform.Angle" Value="360" />
                                </KeyFrame>
                            </Animation>
                        </Style.Animations>
                    </Style>
                </i:Icon.Styles>
            </i:Icon>
            <TextBlock Text="Loading funders..."
                       FontSize="15"
                       Foreground="{DynamicResource TextMutedBrush}"
                       HorizontalAlignment="Center" />
        </StackPanel>

        <!-- ═══════════════════════════════════════════════════════ -->
        <!-- EMPTY STATE: shown when HasFunders = false (not busy)   -->
        <!-- Vue: Users icon, "No Funders Yet", description          -->
        <!-- ═══════════════════════════════════════════════════════ -->
        <Panel IsVisible="{Binding ShowEmptyState}">
            <controls:EmptyState Title="No Funders Yet"
                                 Description="When investors fund your projects, they'll appear here. You can review and approve funding requests from this page."
                                 HasButton="False"
                                 UseCustomIcon="True"
                                 IconData="{StaticResource NavIconUsers}" />
            <!-- Refresh button — visible even when no funders -->
            <Button Name="EmptyRefreshButton"
                    AutomationProperties.AutomationId="FundersRefreshButton"
                    Classes="Primary Light FundersAction MobileAction IconOnly"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Margin="24"
                    IsEnabled="{Binding !IsRefreshing}">
                <i:Icon Value="fa-solid fa-arrows-rotate"
                        FontSize="16"
                        Foreground="{DynamicResource LightPrimaryButtonForeground}">
                    <i:Icon.Styles>
                        <Style Selector="i|Icon.Spinning">
                            <Style.Animations>
                                <Animation Duration="0:0:1" IterationCount="INFINITE">
                                    <KeyFrame Cue="0%">
                                        <Setter Property="RotateTransform.Angle" Value="0" />
                                    </KeyFrame>
                                    <KeyFrame Cue="100%">
                                        <Setter Property="RotateTransform.Angle" Value="360" />
                                    </KeyFrame>
                                </Animation>
                            </Style.Animations>
                        </Style>
                    </i:Icon.Styles>
                </i:Icon>
            </Button>
            <!-- Auto-approve toggle — available even before the first request arrives -->
            <Border Classes="EmptyAutoApproveCard"
                    Background="{DynamicResource Surface}"
                    BorderBrush="{DynamicResource Stroke}"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="16,12"
                    MaxWidth="480"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Bottom">
                <DockPanel>
                    <ToggleSwitch Name="EmptyAutoApproveToggle"
                                  DockPanel.Dock="Right"
                                  IsChecked="{Binding AutoApproveEnabled}"
                                  OnContent="{x:Null}"
                                  OffContent="{x:Null}"
                                  VerticalAlignment="Center"
                                  Margin="12,0,0,0" />
                    <StackPanel Spacing="2" VerticalAlignment="Center">
                        <TextBlock Text="Auto-approve requests"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextStrong}" />
                        <TextBlock Text="New funding requests are checked and approved automatically in the background"
                                   FontSize="12"
                                   Foreground="{DynamicResource TextMuted}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </DockPanel>
            </Border>
        </Panel>

        <!-- ═══════════════════════════════════════════════════════ -->
        <!-- FUNDERS OVERVIEW: shown when HasFunders = true          -->
        <!-- Vue: App.vue desktop Funders page (lines 3152-3335)     -->
        <!-- Layout: DockPanel — header + tabs fixed top, ListBox    -->
        <!--         with VirtualizingStackPanel fills remaining     -->
        <!-- ═══════════════════════════════════════════════════════ -->
        <DockPanel Name="FundersListPanel"
                   IsVisible="{Binding HasFunders}">

            <!-- Fixed header area: doesn't scroll -->
            <StackPanel DockPanel.Dock="Top" MaxWidth="1152"
                        HorizontalAlignment="Stretch"
                        Margin="24,24,24,0">

                <!-- ═══════════════════════════════════════ -->
                <!-- HEADER: Icon + Title + Approve All btn  -->
                <!-- Vue: flex items-center justify-between mb-8 -->
                <!-- ═══════════════════════════════════════ -->
                <DockPanel Classes="FundersHeader" Margin="0,0,0,24">
                    <!-- Left: Icon + Title -->
                    <StackPanel Orientation="Horizontal" Spacing="12" DockPanel.Dock="Left"
                                VerticalAlignment="Center">
                        <!-- Vue: w-10 h-10 rounded-lg bg-black (dark) / bg-gray-100 (light) -->
                        <Border Name="FundersTitleIcon" Width="40" Height="40" CornerRadius="8"
                                Background="{DynamicResource SurfaceLow}">
                            <Viewbox Width="24" Height="24">
                                <Path Data="{StaticResource NavIconUsers}"
                                      Stroke="{DynamicResource TextStrong}"
                                      StrokeThickness="2"
                                      StrokeLineCap="Round"
                                      StrokeJoin="Round"
                                      Width="24" Height="24" Stretch="Uniform" />
                            </Viewbox>
                        </Border>
                        <!-- Vue: text-2xl font-bold -->
                        <TextBlock Name="FundersTitleText"
                                   Text="Funders"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource TextStrong}"
                                   VerticalAlignment="Center" />
                    </StackPanel>

                    <!-- Right: Refresh + Approve All buttons -->
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="8"
                                HorizontalAlignment="Right" VerticalAlignment="Center">
                        <!-- Refresh button -->
                        <Button Name="RefreshButton"
                                AutomationProperties.AutomationId="FundersRefreshButton"
                                Classes="Primary Light FundersAction MobileAction IconOnly"
                                VerticalAlignment="Center"
                                IsEnabled="{Binding !IsRefreshing}">
                            <i:Icon Value="fa-solid fa-arrows-rotate"
                                    FontSize="16"
                                    Foreground="{DynamicResource LightPrimaryButtonForeground}">
                                <i:Icon.Styles>
                                    <Style Selector="i|Icon.Spinning">
                                        <Style.Animations>
                                            <Animation Duration="0:0:1" IterationCount="INFINITE">
                                                <KeyFrame Cue="0%">
                                                    <Setter Property="RotateTransform.Angle" Value="0" />
                                                </KeyFrame>
                                                <KeyFrame Cue="100%">
                                                    <Setter Property="RotateTransform.Angle" Value="360" />
                                                </KeyFrame>
                                            </Animation>
                                        </Style.Animations>
                                    </Style>
                                </i:Icon.Styles>
                            </i:Icon>
                        </Button>
                        <!-- Approve All button -->
                        <Button Name="ApproveAllButton"
                                Classes="Primary FundersAction MobileAction"
                                VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Viewbox Width="16" Height="16" VerticalAlignment="Center">
                                <Path Data="{StaticResource Checkmark}"
                                      Stroke="White"
                                      StrokeThickness="2"
                                      StrokeLineCap="Round"
                                      StrokeJoin="Round"
                                      Width="24" Height="24" Stretch="Uniform" />
                            </Viewbox>
                            <TextBlock Name="ApproveAllText"
                                       Text="Approve All"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="White"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    </StackPanel>
                </DockPanel>

                <!-- ═══════════════════════════════════════ -->
                <!-- AUTO-APPROVE TOGGLE                     -->
                <!-- Background worker (FundersMonitor)      -->
                <!-- approves new requests automatically      -->
                <!-- ═══════════════════════════════════════ -->
                <Border Background="{DynamicResource Surface}"
                        BorderBrush="{DynamicResource Stroke}"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="16,12"
                        Margin="0,0,0,16">
                    <DockPanel>
                        <ToggleSwitch Name="AutoApproveToggle"
                                      AutomationProperties.AutomationId="FundersAutoApproveToggle"
                                      DockPanel.Dock="Right"
                                      IsChecked="{Binding AutoApproveEnabled}"
                                      OnContent="{x:Null}"
                                      OffContent="{x:Null}"
                                      VerticalAlignment="Center"
                                      Margin="12,0,0,0" />
                        <StackPanel Spacing="2" VerticalAlignment="Center">
                            <TextBlock Text="Auto-approve requests"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextStrong}" />
                            <TextBlock Text="New funding requests are checked and approved automatically in the background"
                                       FontSize="12"
                                       Foreground="{DynamicResource TextMuted}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </DockPanel>
                </Border>

                <!-- ═══════════════════════════════════════ -->
                <!-- FILTER TABS                             -->
                <!-- Vue: flex gap-2 mb-6 border-b           -->
                <!-- Active: text-white/text-[#4B7C5A] border-b-2 border-[#4B7C5A] -->
                <!-- Inactive: text-gray-400/text-gray-500    -->
                <!-- ═══════════════════════════════════════ -->
                <Grid>
                    <Border Classes="FilterTabsOuter">
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="4" Name="FilterTabsPanel">
                            <!-- Waiting tab -->
                            <Border Name="TabWaiting"
                                    Grid.Column="0"
                                    Classes="FilterTab FilterTabActive"
                                    Padding="16,8">
                                <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding WaitingCount, StringFormat='Waiting ({0})'}"
                                                Classes="TabLabel"
                                                FontSize="14"
                                                FontWeight="SemiBold" />
                                </Grid>
                            </Border>

                            <!-- Approved tab -->
                            <Border Name="TabApproved"
                                    Grid.Column="1"
                                    Classes="FilterTab"
                                    Padding="16,8">
                                <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding ApprovedCount, StringFormat='Approved ({0})'}"
                                                Classes="TabLabel"
                                                FontSize="14"
                                                FontWeight="SemiBold" />
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>
                    <Border Name="TabRejected" IsVisible="False" />
                </Grid>

                <!-- (Per-tab empty state moved to the fill area below so it centers vertically) -->

            </StackPanel>

            <!-- ═══════════════════════════════════════ -->
            <!-- FILL AREA: empty filter state OR cards  -->
            <!-- Panel fills the remaining height, so    -->
            <!-- the empty state centers vertically      -->
            <!-- ═══════════════════════════════════════ -->
            <Panel>
                <!-- EMPTY FILTER STATE — shown when filteredSignatures is empty -->
                <Panel Name="FilterEmptyPanel" IsVisible="False">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                Spacing="12" MaxWidth="400" Margin="24">
                        <Border Width="64" Height="64" CornerRadius="8"
                                Background="{DynamicResource SurfaceLow}"
                                HorizontalAlignment="Center"
                                Margin="0,0,0,12">
                            <Viewbox Width="32" Height="32">
                                <Path Data="{StaticResource NavIconUsers}"
                                      Stroke="{DynamicResource TextMuted}"
                                      StrokeThickness="2"
                                      StrokeLineCap="Round"
                                      StrokeJoin="Round"
                                      Width="24" Height="24" Stretch="Uniform" />
                            </Viewbox>
                        </Border>
                        <TextBlock Text="{Binding FilterEmptyTitle}"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource TextStrong}"
                                   HorizontalAlignment="Center" />
                        <TextBlock Text="{Binding FilterEmptyDescription}"
                                   FontSize="14"
                                   Foreground="{DynamicResource TextMuted}"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   HorizontalAlignment="Center" />
                    </StackPanel>
                </Panel>

            <!-- ═══════════════════════════════════════ -->
            <!-- SIGNATURE REQUEST CARDS (virtualized)   -->
            <!-- ListBox with VirtualizingStackPanel     -->
            <!-- ═══════════════════════════════════════ -->
            <ListBox Name="SignaturesListPanel"
                     ItemsSource="{Binding FilteredSignatures}"
                     Margin="24,0,24,24"
                     MaxWidth="1152"
                     HorizontalAlignment="Stretch"
                     Background="Transparent"
                     BorderThickness="0"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.Styles>
                    <!-- Remove selection chrome -->
                    <Style Selector="ListBoxItem">
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="Margin" Value="0,0,0,12" />
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    </Style>
                    <Style Selector="ListBoxItem:selected /template/ ContentPresenter#PART_ContentPresenter">
                        <Setter Property="Background" Value="Transparent" />
                    </Style>
                    <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter#PART_ContentPresenter">
                        <Setter Property="Background" Value="Transparent" />
                    </Style>
                    <Style Selector="ListBoxItem:selected:pointerover /template/ ContentPresenter#PART_ContentPresenter">
                        <Setter Property="Background" Value="Transparent" />
                    </Style>
                    <Style Selector="ListBoxItem:selected:focus /template/ ContentPresenter#PART_ContentPresenter">
                        <Setter Property="Background" Value="Transparent" />
                    </Style>
                </ListBox.Styles>
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <VirtualizingStackPanel />
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="funders:SignatureRequestViewModel">
                            <!-- Vue: rounded-xl p-5 border transition-all -->
                            <!-- Dark: bg-[#1a1a1a] border-[#404040] shadow: 0 4px 12px rgba(0,0,0,0.3) -->
                            <!-- Light: bg-white border-[#e5e7eb] shadow: 0 2px 8px rgba(0,0,0,0.08) -->
                            <Border Background="{DynamicResource Surface}"
                                    BorderBrush="{DynamicResource Stroke}"
                                    BorderThickness="1"
                                    CornerRadius="12"
                                    BoxShadow="{DynamicResource ItemShadow}"
                                    Padding="20"
                                                    Classes="SignatureCard">
                                <StackPanel Spacing="0">

                                    <!-- Row: Left info + Right action buttons -->
                                    <!-- Vue: flex items-center justify-between mb-4 -->
                                    <DockPanel Classes="DesktopSignatureLayout" Margin="0,0,0,16">
                                        <!-- Right: Action Buttons — Vue: flex items-center gap-2 -->
                                        <StackPanel DockPanel.Dock="Right"
                                                    Orientation="Horizontal" Spacing="8"
                                                    VerticalAlignment="Center">

                                            <!-- Approve button (waiting only) -->
                                            <!-- Vue: h-[52px] px-4 rounded-lg font-semibold text-sm text-white -->
                                            <!-- background: linear-gradient(135deg, #4B7C5A 0%, #3d6448 100%) -->
                                            <Button Name="ApproveButton"
                                                    Tag="{Binding Id}"
                                                    IsVisible="{Binding IsWaiting}"
                                                    Classes="FundersAction MobileAction"
                                                    Background="{DynamicResource PrimaryGreenBrush}"
                                                    Foreground="White">
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <Viewbox Width="16" Height="16" VerticalAlignment="Center">
                                                        <Path Data="{StaticResource Checkmark}"
                                                              Stroke="White"
                                                              StrokeThickness="2"
                                                              StrokeLineCap="Round"
                                                              StrokeJoin="Round"
                                                              Width="24" Height="24" Stretch="Uniform" />
                                                    </Viewbox>
                                                    <TextBlock Text="Approve"
                                                               FontSize="14"
                                                               FontWeight="SemiBold"
                                                               Foreground="White"
                                                               VerticalAlignment="Center" />
                                                </StackPanel>
                                            </Button>

                                            <!-- Approved status — theme-aware green pill (rounded, subtle
                                                 tint + border; the old hardcoded #1A4B7C5A read badly on dark) -->
                                            <Border IsVisible="{Binding IsApproved}"
                                                    Classes="FundersAction MobileAction"
                                                    Background="{DynamicResource PillGreenBg}"
                                                    BorderBrush="{DynamicResource StagePillBorder}"
                                                    BorderThickness="1"
                                                    CornerRadius="8"
                                                    Padding="16,0"
                                                    VerticalAlignment="Center">
                                                <StackPanel Orientation="Horizontal" Spacing="8"
                                                            HorizontalAlignment="Center"
                                                            VerticalAlignment="Center">
                                                    <Viewbox Width="16" Height="16" VerticalAlignment="Center">
                                                        <Path Data="{StaticResource Checkmark}"
                                                              Stroke="{DynamicResource StagePillText}"
                                                              StrokeThickness="2"
                                                              StrokeLineCap="Round"
                                                              StrokeJoin="Round"
                                                              Width="24" Height="24" Stretch="Uniform" />
                                                    </Viewbox>
                                                    <TextBlock Text="{Binding ApprovedLabel}"
                                                               FontSize="14"
                                                               FontWeight="SemiBold"
                                                               Foreground="{DynamicResource StagePillText}"
                                                               VerticalAlignment="Center" />
                                                </StackPanel>
                                            </Border>

                                            <!-- Reject button (waiting only) -->
                                            <!-- Vue: bg-red-600 hover:bg-red-700 text-white -->
                                            <Button Name="RejectButton"
                                                    Tag="{Binding Id}"
                                                    IsVisible="{Binding IsWaiting}"
                                                    Classes="FundersAction MobileAction"
                                                    Background="#DC2626"
                                                    Foreground="White">
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <Viewbox Width="16" Height="16" VerticalAlignment="Center">
                                                        <Path Data="{StaticResource XMark}"
                                                              Stroke="White"
                                                              StrokeThickness="2"
                                                              StrokeLineCap="Round"
                                                              StrokeJoin="Round"
                                                              Width="24" Height="24" Stretch="Uniform" />
                                                    </Viewbox>
                                                    <TextBlock Text="Reject"
                                                               FontSize="14"
                                                               FontWeight="SemiBold"
                                                               Foreground="White"
                                                               VerticalAlignment="Center" />
                                                </StackPanel>
                                            </Button>

                                            <!-- Rejected status (rejected only) -->
                                            <!-- Vue: bg-red-100 text-red-700 opacity-70 -->
                                            <Border IsVisible="{Binding IsRejected}"
                                                     Classes="FundersAction MobileAction"
                                                    Background="#1ADC2626"
                                                    VerticalAlignment="Center">
                                                <StackPanel Orientation="Horizontal" Spacing="8"
                                                            VerticalAlignment="Center">
                                                    <Viewbox Width="16" Height="16" VerticalAlignment="Center">
                                                        <Path Data="{StaticResource XMark}"
                                                              Stroke="#DC2626"
                                                              StrokeThickness="2"
                                                              StrokeLineCap="Round"
                                                              StrokeJoin="Round"
                                                              Width="24" Height="24" Stretch="Uniform" />
                                                    </Viewbox>
                                                    <TextBlock Text="Rejected"
                                                               FontSize="14"
                                                               FontWeight="SemiBold"
                                                               Foreground="#DC2626"
                                                               VerticalAlignment="Center" />
                                                </StackPanel>
                                            </Border>

                                            <!-- Chat button (always visible) -->
                                            <!-- Vue: btn-secondary-green h-[52px] px-4 rounded-lg -->
                                            <Button Name="ChatButton"
                                                    Tag="{Binding Id}"
                                                     Classes="FundersAction MobileAction"
                                                    Background="Transparent"
                                                    BorderBrush="{DynamicResource PrimaryGreenBrush}"
                                                    BorderThickness="2">
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <i:Icon Value="fa-solid fa-comment"
                                                           FontSize="16"
                                                           Foreground="{DynamicResource PrimaryGreenBrush}"
                                                           VerticalAlignment="Center" />
                                                    <TextBlock Text="Has messages"
                                                               FontSize="14"
                                                               FontWeight="SemiBold"
                                                               Foreground="{DynamicResource PrimaryGreenBrush}"
                                                               VerticalAlignment="Center"
                                                               IsVisible="{Binding HasMessages}" />
                                                </StackPanel>
                                            </Button>

                                            <!-- Expand/Collapse button -->
                                            <!-- Vue: btn-secondary-green h-[52px] px-3 -->
                                            <Button Name="ExpandButton"
                                                    Tag="{Binding Id}"
                                                     Classes="FundersAction MobileAction IconOnly"
                                                    Background="Transparent"
                                                    BorderBrush="{DynamicResource PrimaryGreenBrush}"
                                                    BorderThickness="2"
                                                    HorizontalContentAlignment="Center"
                                                    VerticalContentAlignment="Center">
                                                <Panel>
                                                    <Viewbox Width="16" Height="16"
                                                             IsVisible="{Binding !IsExpanded}">
                                                        <Path Data="{StaticResource ChevronDown}"
                                                              Stroke="{DynamicResource PrimaryGreenBrush}"
                                                              StrokeThickness="2"
                                                              StrokeLineCap="Round"
                                                              StrokeJoin="Round"
                                                              Width="24" Height="24" Stretch="None" />
                                                    </Viewbox>
                                                    <Viewbox Width="16" Height="16"
                                                             IsVisible="{Binding IsExpanded}">
                                                        <Path Data="{StaticResource ChevronUp}"
                                                              Stroke="{DynamicResource PrimaryGreenBrush}"
                                                              StrokeThickness="2"
                                                              StrokeLineCap="Round"
                                                              StrokeJoin="Round"
                                                              Width="24" Height="24" Stretch="None" />
                                                    </Viewbox>
                                                </Panel>
                                            </Button>
                                        </StackPanel>

                                        <!-- Left: Project title + Amount + Date -->
                                        <!-- Vue: flex items-center gap-4 flex-1 -->
                                        <StackPanel Spacing="8" Margin="0,0,16,0">
                                            <!-- Vue: text-base font-semibold mb-2 truncate — project title -->
                                            <TextBlock Text="{Binding ProjectTitle}"
                                                       FontSize="14"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextMuted}"
                                                       TextTrimming="CharacterEllipsis" />

                                            <!-- Vue: text-lg font-bold — amount (or syncing state while
                                                 the indexer hasn't returned the funding tx yet) -->
                                            <StackPanel Orientation="Horizontal" Spacing="4"
                                                        IsVisible="{Binding IsAmountKnown}">
                                                <TextBlock Text="{Binding Amount}"
                                                           FontSize="18"
                                                           FontWeight="Bold"
                                                           Foreground="{DynamicResource TextStrong}" />
                                                <TextBlock Text="{Binding Currency}"
                                                           FontSize="18"
                                                           FontWeight="Bold"
                                                           Foreground="{DynamicResource TextStrong}" />
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Spacing="6"
                                                        IsVisible="{Binding IsAmountPending}">
                                                <i:Icon Value="fa-solid fa-arrows-rotate"
                                                        Classes="Spin"
                                                        FontSize="12"
                                                        Foreground="{DynamicResource TextMuted}"
                                                        VerticalAlignment="Center" />
                                                <TextBlock Text="Syncing amount…"
                                                           FontSize="15"
                                                           FontStyle="Italic"
                                                           Foreground="{DynamicResource TextMuted}"
                                                           VerticalAlignment="Center" />
                                            </StackPanel>

                                            <!-- Vue: calendar icon + date/time text-sm -->
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <i:Icon Value="fa-solid fa-calendar"
                                                       FontSize="16"
                                                       Foreground="{DynamicResource TextMuted}"
                                                       VerticalAlignment="Center" />
                                                <TextBlock FontSize="14"
                                                           Foreground="{DynamicResource TextMuted}"
                                                           VerticalAlignment="Center">
                                                    <Run Text="{Binding Date, Mode=OneWay}" />
                                                    <Run Text=" " />
                                                    <Run Text="{Binding Time, Mode=OneWay}" />
                                                </TextBlock>
                                            </StackPanel>
                                        </StackPanel>
                                    </DockPanel>

                                    <StackPanel Classes="MobileSignatureLayout" Spacing="14" Margin="0,0,0,16">
                                        <Grid ColumnDefinitions="*,Auto">
                                            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="4"
                                                        IsVisible="{Binding IsAmountKnown}">
                                                <TextBlock Text="{Binding Amount}"
                                                           FontSize="18"
                                                           FontWeight="Bold"
                                                           Foreground="{DynamicResource TextStrong}" />
                                                <TextBlock Text="{Binding Currency}"
                                                           FontSize="18"
                                                           FontWeight="Bold"
                                                           Foreground="{DynamicResource TextStrong}" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6"
                                                        IsVisible="{Binding IsAmountPending}">
                                                <i:Icon Value="fa-solid fa-arrows-rotate"
                                                        Classes="Spin"
                                                        FontSize="12"
                                                        Foreground="{DynamicResource TextMuted}"
                                                        VerticalAlignment="Center" />
                                                <TextBlock Text="Syncing amount…"
                                                           FontSize="15"
                                                           FontStyle="Italic"
                                                           Foreground="{DynamicResource TextMuted}"
                                                           VerticalAlignment="Center" />
                                            </StackPanel>

                                            <StackPanel Grid.Column="1">
                                                <Border Classes="SignatureStatusPill"
                                                        IsVisible="{Binding IsWaiting}"
                                                        Background="#F7931A">
                                                    <TextBlock Text="Waiting"
                                                               FontSize="12"
                                                               FontWeight="Bold"
                                                               Foreground="White" />
                                                </Border>
                                                <Border Classes="SignatureStatusPill"
                                                        IsVisible="{Binding IsApproved}"
                                                        Background="{DynamicResource PillGreenBg}"
                                                        BorderBrush="{DynamicResource StagePillBorder}"
                                                        BorderThickness="1">
                                                    <TextBlock Text="{Binding ApprovedLabel}"
                                                               FontSize="12"
                                                               FontWeight="Bold"
                                                               Foreground="{DynamicResource StagePillText}" />
                                                </Border>
                                                <Border Classes="SignatureStatusPill"
                                                        IsVisible="{Binding IsRejected}"
                                                        Background="#DC2626">
                                                    <TextBlock Text="Rejected"
                                                               FontSize="12"
                                                               FontWeight="Bold"
                                                               Foreground="White" />
                                                </Border>
                                            </StackPanel>
                                        </Grid>

                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <i:Icon Value="fa-solid fa-calendar"
                                                    FontSize="14"
                                                    Foreground="{DynamicResource TextMuted}"
                                                    VerticalAlignment="Center" />
                                            <TextBlock FontSize="14"
                                                       Foreground="{DynamicResource TextMuted}"
                                                       VerticalAlignment="Center">
                                                <Run Text="{Binding Date, Mode=OneWay}" />
                                                <Run Text=" " />
                                                <Run Text="{Binding Time, Mode=OneWay}" />
                                            </TextBlock>
                                        </StackPanel>

                                        <TextBlock Text="{Binding ProjectTitle}"
                                                   FontSize="14"
                                                   Foreground="{DynamicResource TextStrong}"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>

                                    <!-- ═══════════════════════════════════════ -->
                                    <!-- EXPANDED DETAILS (npub)                 -->
                                    <!-- Vue: v-if="expandedSignatures[id]"      -->
                                    <!-- pt-4 border-t, "Investor npub" label    -->
                                    <!-- Mono font npub + copy button            -->
                                    <!-- ═══════════════════════════════════════ -->
                                    <Border Name="ExpandedPanel"
                                            Tag="{Binding Id}"
                                            IsVisible="{Binding IsExpanded}"
                                            BorderThickness="0,1,0,0"
                                            BorderBrush="{DynamicResource Stroke}"
                                            Padding="0,16,0,16">
                                        <StackPanel Spacing="8">
                                            <!-- Vue: text-sm font-medium text-gray-400/text-gray-600 -->
                                            <TextBlock Text="Investor npub"
                                                       FontSize="14"
                                                       FontWeight="Medium"
                                                       Foreground="{DynamicResource TextMuted}" />

                                            <!-- Vue: flex items-center gap-2 p-3 rounded-lg bg-[#0A0A0A]/bg-gray-50 border -->
                                            <Border Background="{DynamicResource SurfaceLow}"
                                                    BorderBrush="{DynamicResource Stroke}"
                                                    BorderThickness="1"
                                                    CornerRadius="8"
                                                    Padding="12">
                                                <DockPanel>
                                                    <!-- Copy button -->
                                                    <Button DockPanel.Dock="Right"
                                                            Name="CopyNpubButton"
                                                            Tag="{Binding Npub}"
                                                            Background="Transparent"
                                                            Padding="6"
                                                            CornerRadius="4"
                                                            VerticalAlignment="Top"
                                                            Margin="8,0,0,0">
                                                        <Border Width="16" Height="16">
                                                            <i:Icon Value="fa-solid fa-copy" FontSize="14" Foreground="{DynamicResource TextMuted}" />
                                                        </Border>
                                                    </Button>
                                                    <!-- Vue: flex-1 text-sm break-all font-mono -->
                                                    <TextBlock Text="{Binding Npub}"
                                                               FontSize="13"
                                                               FontFamily="Consolas, Menlo, monospace"
                                                               Foreground="{DynamicResource TextStrong}"
                                                               TextWrapping="Wrap" />
                                                </DockPanel>
                                            </Border>
                                        </StackPanel>
                                    </Border>

                                     <StackPanel Classes="MobileSignatureActions" Spacing="10">
                                         <Grid ColumnDefinitions="*,8,*">
                                             <Button Name="MobileApproveButton"
                                                     Grid.Column="0"
                                                     Tag="{Binding Id}"
                                                     IsVisible="{Binding IsWaiting}"
                                                     Classes="FundersAction MobileAction"
                                                     Background="{DynamicResource PrimaryGreenBrush}"
                                                     Foreground="White">
                                                 <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                                                     <Viewbox Width="16" Height="16" VerticalAlignment="Center">
                                                         <Path Data="{StaticResource Checkmark}"
                                                               Stroke="White"
                                                               StrokeThickness="2"
                                                               StrokeLineCap="Round"
                                                               StrokeJoin="Round"
                                                               Width="24" Height="24" Stretch="Uniform" />
                                                     </Viewbox>
                                                     <TextBlock Text="Approve"
                                                                FontSize="14"
                                                                FontWeight="SemiBold"
                                                                Foreground="White"
                                                                VerticalAlignment="Center" />
                                                 </StackPanel>
                                             </Button>

                                             <Button Name="MobileRejectButton"
                                                     Grid.Column="2"
                                                     Tag="{Binding Id}"
                                                     IsVisible="{Binding IsWaiting}"
                                                     Classes="FundersAction MobileAction"
                                                     Background="#DC2626"
                                                     Foreground="White">
                                                 <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                                                     <Viewbox Width="16" Height="16" VerticalAlignment="Center">
                                                         <Path Data="{StaticResource XMark}"
                                                               Stroke="White"
                                                               StrokeThickness="2"
                                                               StrokeLineCap="Round"
                                                               StrokeJoin="Round"
                                                               Width="24" Height="24" Stretch="Uniform" />
                                                     </Viewbox>
                                                     <TextBlock Text="Reject"
                                                                FontSize="14"
                                                                FontWeight="SemiBold"
                                                                Foreground="White"
                                                                VerticalAlignment="Center" />
                                                 </StackPanel>
                                             </Button>

                                             <Border Grid.Column="0"
                                                     Grid.ColumnSpan="3"
                                                     IsVisible="{Binding IsApproved}"
                                                     Classes="FundersAction MobileAction"
                                                     Background="{DynamicResource PillGreenBg}"
                                                     BorderBrush="{DynamicResource StagePillBorder}"
                                                     BorderThickness="1"
                                                     CornerRadius="8">
                                                 <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                     <Viewbox Width="16" Height="16" VerticalAlignment="Center">
                                                         <Path Data="{StaticResource Checkmark}"
                                                               Stroke="{DynamicResource StagePillText}"
                                                               StrokeThickness="2"
                                                               StrokeLineCap="Round"
                                                               StrokeJoin="Round"
                                                               Width="24" Height="24" Stretch="Uniform" />
                                                     </Viewbox>
                                                     <TextBlock Text="{Binding ApprovedLabel}"
                                                                FontSize="14"
                                                                FontWeight="SemiBold"
                                                                Foreground="{DynamicResource StagePillText}"
                                                                VerticalAlignment="Center" />
                                                 </StackPanel>
                                             </Border>

                                             <Border Grid.Column="0"
                                                     Grid.ColumnSpan="3"
                                                     IsVisible="{Binding IsRejected}"
                                                     Classes="FundersAction MobileAction"
                                                     Background="#FEE2E2">
                                                 <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                     <Viewbox Width="16" Height="16" VerticalAlignment="Center">
                                                         <Path Data="{StaticResource XMark}"
                                                               Stroke="#DC2626"
                                                               StrokeThickness="2"
                                                               StrokeLineCap="Round"
                                                               StrokeJoin="Round"
                                                               Width="24" Height="24" Stretch="Uniform" />
                                                     </Viewbox>
                                                     <TextBlock Text="Rejected"
                                                                FontSize="14"
                                                                FontWeight="SemiBold"
                                                                Foreground="#DC2626"
                                                                VerticalAlignment="Center" />
                                                 </StackPanel>
                                             </Border>
                                         </Grid>

                                         <Grid ColumnDefinitions="*,10,52">
                                             <Button Name="MobileChatButton"
                                                     Grid.Column="0"
                                                     Tag="{Binding Id}"
                                                     Classes="FundersAction MobileAction"
                                                     Background="Transparent"
                                                     BorderBrush="{DynamicResource PrimaryGreenBrush}"
                                                     BorderThickness="2">
                                                 <i:Icon Value="fa-solid fa-comment"
                                                         FontSize="16"
                                                         Foreground="{DynamicResource PrimaryGreenBrush}"
                                                         HorizontalAlignment="Center"
                                                         VerticalAlignment="Center" />
                                             </Button>

                                             <Button Name="MobileExpandButton"
                                                     Grid.Column="2"
                                                     Tag="{Binding Id}"
                                                     Classes="FundersAction MobileAction IconOnly"
                                                     Background="Transparent"
                                                     BorderBrush="{DynamicResource PrimaryGreenBrush}"
                                                     BorderThickness="2"
                                                     HorizontalContentAlignment="Center"
                                                     VerticalContentAlignment="Center">
                                                 <Panel>
                                                     <Viewbox Width="16" Height="16"
                                                              IsVisible="{Binding !IsExpanded}">
                                                         <Path Data="{StaticResource ChevronDown}"
                                                               Stroke="{DynamicResource PrimaryGreenBrush}"
                                                               StrokeThickness="2"
                                                               StrokeLineCap="Round"
                                                               StrokeJoin="Round"
                                                               Width="24" Height="24" Stretch="None" />
                                                     </Viewbox>
                                                     <Viewbox Width="16" Height="16"
                                                              IsVisible="{Binding IsExpanded}">
                                                         <Path Data="{StaticResource ChevronUp}"
                                                               Stroke="{DynamicResource PrimaryGreenBrush}"
                                                               StrokeThickness="2"
                                                               StrokeLineCap="Round"
                                                               StrokeJoin="Round"
                                                               Width="24" Height="24" Stretch="None" />
                                                     </Viewbox>
                                                 </Panel>
                                             </Button>
                                         </Grid>
                                     </StackPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Panel>

        </DockPanel>
    </Panel>
</UserControl>
