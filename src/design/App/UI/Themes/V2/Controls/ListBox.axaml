<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <Style Selector="ListBox.Transparent">
        <Setter Property="Background" Value="Transparent" />
    </Style>
        
    <Style Selector=":is(ItemsControl).Horizontal">
        <Setter Property="ItemsPanel">
            <Setter.Value>
                <ItemsPanelTemplate>
                    <UniformGrid Rows="1" ColumnSpacing="10" />
                </ItemsPanelTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Like Horizontal, but items keep their natural width and wrap to the next
         line when the container is too narrow (mobile). Prevents the char-by-char
         text wrapping seen with UniformGrid on compact widths (issue #920). -->
    <Style Selector=":is(ItemsControl).HorizontalWrap">
        <Setter Property="ItemsPanel">
            <Setter.Value>
                <ItemsPanelTemplate>
                    <WrapPanel Orientation="Horizontal" ItemSpacing="10" LineSpacing="10" />
                </ItemsPanelTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    
    <!-- Two-column fill grid: items stretch to share the row equally and wrap
         into balanced rows. Used for 4-item preset rows on compact widths. -->
    <Style Selector=":is(ItemsControl).Grid2">
        <Setter Property="ItemsPanel">
            <Setter.Value>
                <ItemsPanelTemplate>
                    <UniformGrid Columns="2" ColumnSpacing="10" RowSpacing="10" />
                </ItemsPanelTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style Selector=":is(ItemsControl).Vertical">
        <Setter Property="ItemsPanel">
            <Setter.Value>
                <ItemsPanelTemplate>
                    <StackPanel Classes="Gap-M" />
                </ItemsPanelTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    
    <Style Selector=":is(ItemsControl).VerticalBigGap">
        <Setter Property="ItemsPanel">
            <Setter.Value>
                <ItemsPanelTemplate>
                    <StackPanel Classes="Gap-XL" />
                </ItemsPanelTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Styles.Resources>
        
        <ControlTheme x:Key="ButtonizedListBoxItem" TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
            <Setter Property="Padding" Value="10"></Setter>
            <!-- Standard preset-pill height: every preset pill matches the
                 two-line target-amount pills so mixed rows align. -->
            <Setter Property="MinHeight" Value="60" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <!-- Transparent + Stroke outline (matches DurPresetBtn); the old
                 SurfaceHover fill read as a washed-out grey pill in dark mode -->
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource TextStrong}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="{DynamicResource Stroke}" />
            
            <Setter Property="CornerRadius" Value="10" />

            <Style Selector="^:pointerover /template/ ContentPresenter#PART_ContentPresenter">
                <Setter Property="BorderBrush" Value="{DynamicResource Accent}" />
                <Setter Property="Background" Value="{DynamicResource SurfaceLow}" />
            </Style>
            <Style Selector="^:selected /template/ ContentPresenter#PART_ContentPresenter">
                <Setter Property="Background" Value="{DynamicResource Accent}" />
                <Setter Property="BorderBrush" Value="{DynamicResource Accent}" />
                <Setter Property="Foreground" Value="White" />
            </Style>
        </ControlTheme>
        
        <ControlTheme x:Key="ButtonizedAccentListBoxItem" TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
            <Setter Property="Padding" Value="10" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <!-- Standard preset-pill height (see ButtonizedListBoxItem) -->
            <Setter Property="MinHeight" Value="60" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <!-- Transparent + Stroke outline (matches DurPresetBtn) -->
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource TextStrong}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="{DynamicResource Stroke}" />
            <Setter Property="CornerRadius" Value="10" />

            <Style Selector="^:pointerover /template/ ContentPresenter#PART_ContentPresenter">
                <Setter Property="BorderBrush" Value="{DynamicResource Accent}" />
                <Setter Property="Background" Value="{DynamicResource SurfaceLow}" />
            </Style>
            <Style Selector="^:selected /template/ ContentPresenter#PART_ContentPresenter">
                <Setter Property="Background" Value="{DynamicResource Accent}" />
                <Setter Property="BorderBrush" Value="{DynamicResource Accent}" />
                <Setter Property="Foreground" Value="White" />
            </Style>
        </ControlTheme>
        
        <ControlTheme x:Key="SelectorListBoxItem" TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
            <Setter Property="Padding" Value="20" />
            <Setter Property="Background" Value="{DynamicResource Surface}" />
            <Setter Property="Foreground" Value="{DynamicResource TextStrong}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Stroke}" />
            <Setter Property="BorderThickness" Value="2" />
            
            <Setter Property="CornerRadius" Value="10" />

            <Style Selector="^:selected /template/ ContentPresenter#PART_ContentPresenter">
                <Setter Property="Background" Value="{DynamicResource Surface}" />
                <Setter Property="BorderBrush" Value="{DynamicResource Accent}" />

            </Style>
            <Style Selector="^:pointerover /template/ ContentPresenter#PART_ContentPresenter">
                <Setter Property="BorderBrush" Value="{DynamicResource Accent}" />
                <Setter Property="Background" Value="{DynamicResource Surface}" />
            </Style>
        </ControlTheme>
        
        <ControlTheme x:Key="SmallSelectorListBoxItem" TargetType="ListBoxItem" BasedOn="{StaticResource SelectorListBoxItem}">
            <Setter Property="Padding" Value="10" />
        </ControlTheme>

    </Styles.Resources>
    
    <Design.PreviewWith>
        <Border Padding="20">
            <WrapPanel ItemSpacing="10">
                <ListBoxItem IsSelected="True" Content="Selected" Theme="{StaticResource ButtonizedListBoxItem}" />
                <ListBoxItem IsSelected="False" Content="Unselected" Theme="{StaticResource ButtonizedListBoxItem}" />
                
                <ListBoxItem IsSelected="True" Content="Selected" Theme="{StaticResource ButtonizedAccentListBoxItem}" />
                <ListBoxItem IsSelected="False" Content="Unselected" Theme="{StaticResource ButtonizedAccentListBoxItem}" />
            </WrapPanel>
        </Border>
    </Design.PreviewWith>
</Styles>