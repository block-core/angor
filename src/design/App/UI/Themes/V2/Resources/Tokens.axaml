<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Font families: matches Vue app.css angor-font-sans-serif -->
    <FontFamily x:Key="FontFamilySans">Roboto</FontFamily>

    <!-- Spacing scale (4px base): 8, 12, 16, 24, 32, 48 -->
    <x:Double x:Key="Spacing2">8</x:Double>
    <x:Double x:Key="Spacing3">12</x:Double>
    <x:Double x:Key="Spacing4">16</x:Double>
    <x:Double x:Key="Spacing5">24</x:Double>
    <x:Double x:Key="Spacing6">32</x:Double>
    <x:Double x:Key="Spacing8">48</x:Double>

    <!-- Typography scale -->
    <x:Double x:Key="FontSizeSm">12</x:Double>
    <x:Double x:Key="FontSizeBase">14</x:Double>
    <x:Double x:Key="FontSizeLg">16</x:Double>

    <!-- Radius scale (matching Storybook: buttons=12px, content cards=16px) -->
    <CornerRadius x:Key="RadiusSm">6</CornerRadius>
    <CornerRadius x:Key="RadiusMd">12</CornerRadius>
    <CornerRadius x:Key="RadiusLg">16</CornerRadius>

    <!-- Common padding/margin thicknesses -->
    <Thickness x:Key="Thickness8">8</Thickness>
    <Thickness x:Key="Thickness16">16</Thickness>
    <Thickness x:Key="Thickness32">32</Thickness>
    <Thickness x:Key="PaddingX6">32,0,32,0</Thickness>
    <Thickness x:Key="PaddingY3">0,12,0,12</Thickness>
    <Thickness x:Key="PaddingBadge">12,8,12,8</Thickness>
    <Thickness x:Key="MarginT4">0,16,0,0</Thickness>

    <!-- Modal sizing tiers (reference: Deploy/Invest Wallet Selector) -->
    <!-- MinWidth kept at 320 on every tier so mobile respects a 16px gutter left/right via
         Margin=16 in Modals.axaml instead of forcing overflow. MaxWidth caps desktop card size. -->
    <!-- Standard: default for most modals (password prompts, wallet pickers, confirmations) -->
    <x:Double x:Key="ModalMinWidth">320</x:Double>
    <x:Double x:Key="ModalMaxWidth">512</x:Double>
    <!-- Wide: for tabular / multi-column content (recovery, penalties, JSON viewers)
         MinWidth kept small for mobile-safe behavior; MaxWidth drives desktop expansion. -->
    <x:Double x:Key="ModalWideMinWidth">320</x:Double>
    <x:Double x:Key="ModalWideMaxWidth">672</x:Double>
    <!-- Full: panel-like modals (Funds section: Create/Send/Receive/UTXOs) -->
    <x:Double x:Key="ModalFullMinWidth">320</x:Double>
    <x:Double x:Key="ModalFullMaxWidth">1030</x:Double>
    <x:Double x:Key="ModalFullMaxHeight">720</x:Double>

</ResourceDictionary>
