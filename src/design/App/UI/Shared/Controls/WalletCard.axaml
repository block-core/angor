<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:App.UI.Shared.Controls"
        xmlns:i="https://github.com/projektanker/icons.avalonia">

    <Design.PreviewWith>
        <StackPanel Spacing="8" Width="500">
            <ThemeVariantScope RequestedThemeVariant="Dark">
                <Border Background="{DynamicResource AppBackground}" Padding="16">
                    <StackPanel Spacing="0">
                        <controls:WalletCard WalletName="Main Wallet" Balance="5.2340 BTC" WalletType="Hot Wallet" Label="Investments" />
                        <controls:WalletCard WalletName="Savings" Balance="4.7660 BTC" WalletType="Cold Storage" />
                    </StackPanel>
                </Border>
            </ThemeVariantScope>
            <ThemeVariantScope RequestedThemeVariant="Light">
                <Border Background="{DynamicResource AppBackground}" Padding="16">
                    <controls:WalletCard WalletName="Main Wallet" Balance="5.2340 BTC" WalletType="Hot Wallet" Label="Trading" />
                </Border>
            </ThemeVariantScope>
        </StackPanel>
    </Design.PreviewWith>

    <!--
        Vue wallet card row (Funds.vue):
        Card row: padding 20px 24px, border-bottom 1px solid
        Title row: name (16px semibold left) + balance (16px semibold right)
        Bottom row: type (13px muted left) + label pill (right, optional)
        Right side: 3 action buttons (Send filled, Receive outlined, UTXO outlined) gap 8, each 32x32
    -->
    <Style Selector="controls|WalletCard">
        <Setter Property="Template">
            <ControlTemplate TargetType="controls:WalletCard">
                <Border Name="CardRoot"
                        Background="Transparent"
                        BorderBrush="{DynamicResource Stroke}"
                        BorderThickness="0,0,0,1"
                        Padding="20,16,24,16">
                    <Grid Name="CardGrid" ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto,Auto">
                        <!-- Left: Bitcoin icon 40x40 -->
                        <Border Grid.Column="0"
                                Width="40" Height="40"
                                CornerRadius="8"
                                Background="#fef3c7"
                                Padding="8"
                                VerticalAlignment="Center"
                                Margin="0,0,12,0">
                            <i:Icon Value="fa-brands fa-bitcoin"
                                   FontSize="20"
                                   Foreground="#f59e0b" />
                        </Border>

                        <!-- Center: Name+Balance row, Type+Label row -->
                        <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center"
                                    MinWidth="0">
                            <!-- Top row: name left, balance right -->
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Grid.Column="0"
                                           Text="{TemplateBinding WalletName}"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextStrong}"
                                           VerticalAlignment="Center"
                                           TextWrapping="NoWrap"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock Grid.Column="1"
                                           Text="{TemplateBinding Balance}"
                                           AutomationProperties.AutomationId="WalletCardBalanceText"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextStrong}"
                                           VerticalAlignment="Center" />
                            </Grid>
                            <!-- Pending balance row (yellow) — hidden when empty -->
                            <Grid ColumnDefinitions="*,Auto"
                                  IsVisible="{TemplateBinding PendingBalance, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                <TextBlock Grid.Column="0"
                                           Text="Pending"
                                           FontSize="12"
                                           Foreground="#EAB308" />
                                <TextBlock Grid.Column="1"
                                           Text="{TemplateBinding PendingBalance}"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="#EAB308" />
                            </Grid>
                            <!-- Reserved balance row (blue) — hidden when empty -->
                            <Grid ColumnDefinitions="*,Auto"
                                  IsVisible="{TemplateBinding ReservedBalance, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                <TextBlock Grid.Column="0"
                                           Text="Reserved"
                                           FontSize="12"
                                           Foreground="#3B82F6" />
                                <TextBlock Grid.Column="1"
                                           Text="{TemplateBinding ReservedBalance}"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="#3B82F6" />
                            </Grid>
                            <!-- Bottom row: type left, label pill right -->
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Grid.Column="0"
                                           Text="{TemplateBinding WalletType}"
                                           FontSize="12"
                                           Foreground="{DynamicResource TextMuted}"
                                           TextWrapping="NoWrap"
                                           TextTrimming="CharacterEllipsis" />
                                <Border Grid.Column="1"
                                        IsVisible="{TemplateBinding Label, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                        Background="{DynamicResource PillGreenBg}"
                                        BorderBrush="{DynamicResource PillGreenBorder}"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        Padding="6,1">
                                    <TextBlock Text="{TemplateBinding Label}"
                                               FontSize="11"
                                               Foreground="{DynamicResource PillGreenText}" />
                                </Border>
                            </Grid>
                        </StackPanel>

                        <!-- Right: action buttons (moves to row 1 on compact via code-behind) -->
                        <Grid Name="ActionButtons"
                              Grid.Column="2"
                              Grid.Row="0"
                              ColumnDefinitions="96,96,32,32,32"
                              RowDefinitions="Auto"
                              ColumnSpacing="8"
                              VerticalAlignment="Center"
                              Margin="16,0,0,0">
                            <!-- Send button — labeled filled green action -->
                             <Button Name="BtnSend"
                                     Grid.Column="0"
                                     AutomationProperties.AutomationId="WalletCardBtnSend"
                                     Width="96" Height="32"
                                     Padding="14,0"
                                    CornerRadius="6"
                                    BorderThickness="0"
                                    Cursor="Hand"
                                    ToolTip.Tip="Send">
                                <Button.Background>
                                    <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                                        <GradientStop Color="{StaticResource PrimaryGreen}" Offset="0" />
                                        <GradientStop Color="#3D6448" Offset="1" />
                                    </LinearGradientBrush>
                                </Button.Background>
                                <TextBlock Text="Send"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           Foreground="White"
                                           VerticalAlignment="Center" />
                            </Button>
                            <!-- Receive button — labeled outlined green action -->
                             <Button Name="BtnReceive"
                                     Grid.Column="1"
                                     AutomationProperties.AutomationId="WalletCardBtnReceive"
                                     Width="96" Height="32"
                                    Padding="14,0"
                                    CornerRadius="6"
                                    Background="Transparent"
                                    BorderBrush="{DynamicResource PrimaryGreenBrush}"
                                    BorderThickness="2"
                                    Cursor="Hand"
                                    ToolTip.Tip="Receive">
                                <TextBlock Text="Receive"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource PrimaryGreenBrush}"
                                           VerticalAlignment="Center" />
                            </Button>
                            <!-- UTXO / Details button — 32x32 OUTLINED green -->
                             <Button Name="BtnUtxo"
                                     Grid.Column="2"
                                     AutomationProperties.AutomationId="WalletCardBtnUtxo"
                                    Width="32" Height="32"
                                    Padding="0"
                                    CornerRadius="6"
                                    Background="Transparent"
                                    BorderBrush="{DynamicResource PrimaryGreenBrush}"
                                    BorderThickness="2"
                                    Cursor="Hand"
                                    ToolTip.Tip="UTXOs">
                                <i:Icon Value="fa-solid fa-coins"
                                       FontSize="14"
                                       Foreground="{DynamicResource PrimaryGreenBrush}" />
                            </Button>
                            <!-- Refresh button — 32x32 OUTLINED green -->
                             <Button Name="BtnRefresh"
                                     Grid.Column="3"
                                     AutomationProperties.AutomationId="WalletCardBtnRefresh"
                                    Width="32" Height="32"
                                    Padding="0"
                                    CornerRadius="6"
                                    Background="Transparent"
                                    BorderBrush="{DynamicResource PrimaryGreenBrush}"
                                    BorderThickness="2"
                                    Cursor="Hand"
                                    ToolTip.Tip="Refresh Balance">
                                <Panel>
                                    <i:Icon Value="fa-solid fa-arrows-rotate"
                                           FontSize="14"
                                           Foreground="{DynamicResource PrimaryGreenBrush}"
                                           IsVisible="{Binding !IsRefreshing, RelativeSource={RelativeSource TemplatedParent}}" />
                                    <i:Icon Value="fa-solid fa-spinner"
                                           FontSize="14"
                                           Foreground="{DynamicResource PrimaryGreenBrush}"
                                           IsVisible="{TemplateBinding IsRefreshing}"
                                           RenderTransformOrigin="50%,50%">
                                        <i:Icon.RenderTransform>
                                            <RotateTransform />
                                        </i:Icon.RenderTransform>
                                        <i:Icon.Styles>
                                            <Style Selector="i|Icon[IsVisible=True]">
                                                <Style.Animations>
                                                    <Animation Duration="0:0:1" IterationCount="INFINITE">
                                                        <KeyFrame Cue="0%">
                                                            <Setter Property="RotateTransform.Angle" Value="0" />
                                                        </KeyFrame>
                                                        <KeyFrame Cue="100%">
                                                            <Setter Property="RotateTransform.Angle" Value="360" />
                                                        </KeyFrame>
                                                    </Animation>
                                                </Style.Animations>
                                            </Style>
                                        </i:Icon.Styles>
                                    </i:Icon>
                                </Panel>
                            </Button>
                            <!-- Faucet / Get Test Coins button — 32x32 OUTLINED orange, testnet only -->
                             <Button Name="BtnFaucet"
                                     Grid.Column="4"
                                     AutomationProperties.AutomationId="WalletCardBtnFaucet"
                                    Width="32" Height="32"
                                    Padding="0"
                                    CornerRadius="6"
                                    Background="Transparent"
                                    BorderBrush="#f59e0b"
                                    BorderThickness="2"
                                    Cursor="Hand"
                                    ToolTip.Tip="Get Test Coins"
                                    IsVisible="{TemplateBinding ShowFaucet}">
                                <i:Icon Value="fa-solid fa-faucet-drip"
                                       FontSize="14"
                                       Foreground="#f59e0b" />
                            </Button>
                        </Grid>
                    </Grid>
                </Border>
            </ControlTemplate>
        </Setter>
    </Style>

</Styles>
