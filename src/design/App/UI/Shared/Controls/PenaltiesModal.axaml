<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:i="https://github.com/projektanker/icons.avalonia"
             xmlns:portfolio="clr-namespace:App.UI.Sections.Portfolio"
             mc:Ignorable="d" d:DesignWidth="750" d:DesignHeight="500"
             x:Class="App.UI.Shared.Controls.PenaltiesModal"
             x:DataType="portfolio:PortfolioViewModel">

    <!--
        Penalties Details Modal - Vue InvestmentDetail.vue lines 563-626
        Shell modal pattern: card content only, no backdrop (shell provides blur + backdrop).
        max-w-2xl (~672px), table with PROJECT ID / AMOUNT IN PENALTY / DAYS REMAINING
        Bound to Penalties — a fresh, wallet-wide scan from the SDK's GetPenalties operation
        (triggered from PortfolioView's Penalties button), not a per-investment cache.
    -->

    <Panel>
        <Border Classes="ModalCard Wide"
                CornerRadius="16"
                Background="{DynamicResource RecoveryModalBg}"
                BorderBrush="{DynamicResource RecoveryModalBorder}"
                BorderThickness="1"
                BoxShadow="0 25 50 0 #40000000"
                ClipToBounds="True">
            <DockPanel>
                <!-- Header: lock icon + title + close -->
                <Border DockPanel.Dock="Top"
                        Padding="24"
                        BorderBrush="{DynamicResource ModalHeaderBorder}"
                        BorderThickness="0,0,0,1">
                    <Grid ColumnDefinitions="Auto,12,*,Auto">
                        <i:Icon Grid.Column="0"
                                Value="fa-solid fa-lock"
                                FontSize="20"
                                Foreground="{DynamicResource TextMuted}"
                                VerticalAlignment="Center" />
                        <TextBlock Grid.Column="2"
                                   Text="Penalties Details"
                                   FontSize="22" FontWeight="Bold"
                                   Foreground="{DynamicResource TextStrong}"
                                   VerticalAlignment="Center" />
                        <Button Name="CloseButton" Classes="ModalCloseBtn" Grid.Column="3"
                                Width="36" Height="36"
                                VerticalAlignment="Center" />
                    </Grid>
                </Border>

                <!-- Scrollable body with table -->
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              MaxHeight="500">
                    <StackPanel Margin="24">

                        <!-- Table -->
                        <Border BorderBrush="{DynamicResource RecoveryTableHeaderBorder}"
                                BorderThickness="1"
                                CornerRadius="8"
                                ClipToBounds="True">
                            <StackPanel>

                                <!-- Table header row -->
                                <Border BorderBrush="{DynamicResource RecoveryTableHeaderBorder}"
                                        BorderThickness="0,0,0,2"
                                        Padding="0">
                                    <Grid ColumnDefinitions="3*,2*,2*">
                                        <TextBlock Grid.Column="0"
                                                   Text="PROJECT"
                                                   FontSize="12" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource PenaltyTableHeaderText}"
                                                   Padding="16,12"
                                                   VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="1"
                                                   Text="AMOUNT IN PENALTY"
                                                   FontSize="12" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource PenaltyTableHeaderText}"
                                                   Padding="16,12"
                                                   VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="2"
                                                   Text="DAYS REMAINING"
                                                   FontSize="12" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource PenaltyTableHeaderText}"
                                                   Padding="16,12"
                                                   VerticalAlignment="Center" />
                                    </Grid>
                                </Border>

                                <!-- Loading state -->
                                <Border Padding="24" IsVisible="{Binding IsLoadingPenalties}">
                                    <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Center">
                                        <i:Icon Value="fa-solid fa-spinner" FontSize="16"
                                                Foreground="{DynamicResource TextMuted}"
                                                RenderTransformOrigin="50%,50%">
                                            <i:Icon.RenderTransform>
                                                <RotateTransform />
                                            </i:Icon.RenderTransform>
                                            <i:Icon.Styles>
                                                <Style Selector="i|Icon[IsVisible=True]">
                                                    <Style.Animations>
                                                        <Animation Duration="0:0:1" IterationCount="INFINITE">
                                                            <KeyFrame Cue="0%">
                                                                <Setter Property="RotateTransform.Angle" Value="0" />
                                                            </KeyFrame>
                                                            <KeyFrame Cue="100%">
                                                                <Setter Property="RotateTransform.Angle" Value="360" />
                                                            </KeyFrame>
                                                        </Animation>
                                                    </Style.Animations>
                                                </Style>
                                            </i:Icon.Styles>
                                        </i:Icon>
                                        <TextBlock Text="Checking for penalties…"
                                                   FontSize="14"
                                                   Foreground="{DynamicResource TextMuted}" />
                                    </StackPanel>
                                </Border>

                                <!-- Empty state -->
                                <Border Padding="24"
                                        IsVisible="{Binding ShowEmptyPenaltiesState}">
                                    <TextBlock Text="No investments currently in penalty."
                                               FontSize="14"
                                               Foreground="{DynamicResource TextMuted}"
                                               HorizontalAlignment="Center" />
                                </Border>

                                <!-- Dynamic rows from real data -->
                                <ItemsControl ItemsSource="{Binding Penalties}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="portfolio:PenaltyItemViewModel">
                                            <Border BorderBrush="{DynamicResource RecoveryTableRowBorder}"
                                                    BorderThickness="0,0,0,1"
                                                    Padding="0">
                                                <Grid ColumnDefinitions="3*,2*,2*">
                                                    <Border Grid.Column="0"
                                                            Padding="16,16"
                                                            VerticalAlignment="Center">
                                                        <StackPanel Spacing="2">
                                                            <TextBlock Text="{Binding ProjectName}"
                                                                       IsVisible="{Binding HasProjectName}"
                                                                       FontSize="14" FontWeight="SemiBold"
                                                                       Foreground="{DynamicResource PenaltyTableText}"
                                                                       TextTrimming="CharacterEllipsis" />
                                                            <TextBlock Text="{Binding ProjectIdentifier}"
                                                                       FontSize="12"
                                                                       FontFamily="Cascadia Mono, Consolas, monospace"
                                                                       Foreground="{DynamicResource TextMuted}"
                                                                       TextTrimming="CharacterEllipsis" />
                                                        </StackPanel>
                                                    </Border>
                                                    <TextBlock Grid.Column="1"
                                                               Text="{Binding AmountLabel}"
                                                               FontSize="13" FontWeight="SemiBold"
                                                               Foreground="{DynamicResource PenaltyAmountText}"
                                                               Padding="16,16"
                                                               VerticalAlignment="Center" />
                                                    <Border Grid.Column="2"
                                                            Padding="16,16"
                                                            VerticalAlignment="Center">
                                                        <Border Background="{DynamicResource PenaltyPillBg}"
                                                                BorderBrush="{DynamicResource PenaltyPillBorder}"
                                                                BorderThickness="1"
                                                                CornerRadius="12"
                                                                Padding="12,6"
                                                                HorizontalAlignment="Left">
                                                            <TextBlock Text="{Binding StatusText}"
                                                                       FontSize="12" FontWeight="SemiBold"
                                                                       Foreground="{DynamicResource PenaltyPillText}" />
                                                        </Border>
                                                    </Border>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>
    </Panel>
</UserControl>
