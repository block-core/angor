<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="App.UI.Shared.Controls.SkeletonInvestmentDetailView">
    <!-- Skeleton matching InvestmentDetailView — single-column stacked layout
         that works on both mobile and desktop. Shown briefly during first inflate. -->
    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Disabled">
    <StackPanel Spacing="20" Margin="16,16,16,24">

        <!-- Mobile progress stages skeleton -->
        <StackPanel Spacing="12">
            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                <Border Classes="Skeleton Pill" Width="100" />
                <Border Classes="Skeleton Pill" Width="90" />
                <Border Classes="Skeleton Pill" Width="100" />
            </StackPanel>
        </StackPanel>

        <!-- Project card skeleton — full width -->
        <Border CornerRadius="16" BorderThickness="1"
                BorderBrush="{DynamicResource Stroke}"
                Background="{DynamicResource Surface}"
                BoxShadow="{DynamicResource ItemShadow}"
                ClipToBounds="True">
            <StackPanel>
                <Border Classes="Skeleton" Height="160" CornerRadius="0" />
                <Panel Margin="20,0,0,0" Height="32">
                    <Border Classes="Skeleton Circle" HorizontalAlignment="Left"
                            VerticalAlignment="Top" Margin="0,-32,0,0" />
                </Panel>
                <StackPanel Margin="20,16,20,20" Spacing="8">
                    <Border Classes="Skeleton TextHeading" Width="240" HorizontalAlignment="Left" />
                    <StackPanel Spacing="6">
                        <Border Classes="Skeleton TextLine" />
                        <Border Classes="Skeleton TextLine" Width="200" HorizontalAlignment="Left" />
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Status card skeleton — full width -->
        <Border CornerRadius="16" BorderThickness="1"
                BorderBrush="{DynamicResource Stroke}"
                Background="{DynamicResource Surface}"
                BoxShadow="{DynamicResource ItemShadow}"
                Padding="20">
            <StackPanel Spacing="14">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Border Classes="Skeleton Pill" />
                    <Border Classes="Skeleton Pill" Width="80" />
                </StackPanel>
                <Border Classes="Skeleton TextHeading" Width="180" HorizontalAlignment="Left" />
                <StackPanel Spacing="8">
                    <Border Classes="Skeleton TextLine" />
                    <Border Classes="Skeleton TextLine" Width="220" HorizontalAlignment="Left" />
                </StackPanel>
                <Border Classes="Skeleton" Height="44" CornerRadius="8" Margin="0,4,0,0" />
            </StackPanel>
        </Border>

        <!-- Stats card skeleton — full width, stacked stat cards -->
        <Border CornerRadius="16" Padding="20"
                Background="{DynamicResource SurfaceLow}">
            <StackPanel Spacing="12">
                <Border Classes="Skeleton TextHeading" Width="140" HorizontalAlignment="Left" />
                <Border Classes="Skeleton" Height="64" CornerRadius="12" />
                <Border Classes="Skeleton" Height="64" CornerRadius="12" />
                <Border Classes="Skeleton" Height="64" CornerRadius="12" />
                <Border Classes="Skeleton" Height="64" CornerRadius="12" />
                <Border Classes="Skeleton Bar" />
            </StackPanel>
        </Border>

        <!-- Info card skeleton — full width, stacked -->
        <Border CornerRadius="16" BorderThickness="1"
                BorderBrush="{DynamicResource Stroke}"
                Background="{DynamicResource Surface}"
                Padding="20">
            <StackPanel Spacing="12">
                <Border Classes="Skeleton TextHeading" Width="200" HorizontalAlignment="Left" />
                <Border Classes="Skeleton" Height="56" CornerRadius="12" />
                <Border Classes="Skeleton" Height="56" CornerRadius="12" />
                <Border Classes="Skeleton" Height="56" CornerRadius="12" />
                <Border Classes="Skeleton" Height="56" CornerRadius="12" />
            </StackPanel>
        </Border>

        <!-- Stages skeleton — mobile cards style -->
        <Border CornerRadius="16" BorderThickness="1"
                BorderBrush="{DynamicResource Stroke}"
                Background="{DynamicResource Surface}"
                Padding="20">
            <StackPanel Spacing="10">
                <Border Classes="Skeleton TextHeading" Width="180" HorizontalAlignment="Left" />
                <Border Classes="Skeleton" Height="52" CornerRadius="10" />
                <Border Classes="Skeleton" Height="52" CornerRadius="10" />
                <Border Classes="Skeleton" Height="52" CornerRadius="10" />
            </StackPanel>
        </Border>
    </StackPanel>
    </ScrollViewer>
</UserControl>
