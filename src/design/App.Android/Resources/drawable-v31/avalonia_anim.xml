<animated-vector
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt">
    <aapt:attr name="android:drawable">
        <!--
            Android 12+ splash applies a circular mask at ~2/3 of the drawable size.
            Use a 288x288dp canvas (Android splash standard without icon background).
            Scale the 120x129 logo to ~135dp and center its geometric centroid
            (roughly 58.6, 65.5 in local path coords) at the canvas center (144, 144)
            so the full A + bottom triangle dots fit inside the 192dp safe circle.
            Ref: https://developer.android.com/about/versions/12/features/splash-screen
        -->
        <vector
            android:name="vector"
            android:width="288dp"
            android:height="288dp"
            android:viewportWidth="288"
            android:viewportHeight="288">
            <group
                android:name="wrapper"
                android:pivotX="65.15"
                android:pivotY="65.5"
                android:scaleX="1.0"
                android:scaleY="1.0"
                android:translateX="78.85"
                android:translateY="78.5">
                <group android:name="logo_group">
                    <!-- Main triangular shape with inner cutout -->
                    <path
                        android:name="main_outer"
                        android:pathData="M57.69,3.69c1.11,-1.24,2.34,-1.56,3.54,-0.78c0.63,0.43,1.27,1.03,1.65,1.7c0.98,1.7,1.9,3.44,2.75,5.22c1.27,2.59,2.47,5.25,3.7,7.88c1.87,4.01,3.73,8.03,5.6,12.04c1.46,3.12,2.94,6.21,4.4,9.34c1.29,2.77,2.58,5.54,3.89,8.31c1.33,2.88,2.69,5.72,4.02,8.59c1.3,2.73,2.56,5.5,3.86,8.24c1.64,3.55,3.32,7.03,4.9,10.62c0.47,0.99,0.79,2.09,1.08,3.2c0.57,2.45,-0.19,4.51,-1.87,5.93c-1.52,1.28,-3.13,2.31,-4.75,3.34c-2.85,1.81,-5.72,3.55,-8.57,5.29c-3.01,1.85,-6.01,3.66,-9.02,5.5c-2.75,1.7,-5.51,3.41,-8.29,5.04c-1.52,0.92,-3.1,1.49,-3.96,1.49c-2.75,-0.04,-4.46,-0.85,-6.07,-1.85c-3.13,-1.88,-6.23,-3.8,-9.33,-5.72c-5.17,-3.17,-10.33,-6.35,-15.47,-9.55c-1.36,-0.82,-2.72,-1.63,-3.99,-2.59c-0.82,-0.6,-1.58,-1.42,-2.21,-2.27c-1.2,-1.63,-1.3,-3.59,-0.6,-5.47c0.98,-2.63,2.15,-5.18,3.32,-7.7c1.74,-3.83,3.54,-7.6,5.35,-11.4c2.12,-4.54,4.27,-9.09,6.42,-13.67c2.15,-4.58,4.3,-9.23,6.49,-13.85c1.83,-3.98,3.73,-7.95,5.6,-11.93c1.49,-3.16,2.94,-6.39,4.46,-9.55c0.89,-1.88,1.71,-3.87,3.1,-5.4z"
                        android:fillColor="#00000000"
                        android:strokeColor="#4B7C5A"
                        android:strokeAlpha="0"
                        android:strokeWidth="4"/>

                    <!-- Inner triangle cutout -->
                    <path
                        android:name="main_inner"
                        android:pathData="M59.78,44.48c-4.46,9.48,-8.92,18.99,-13.38,28.55c1.2,0.75,2.34,1.49,3.48,2.17c3.1,1.92,6.2,3.8,9.3,5.72c0.51,0.32,0.95,0.32,1.46,0.04c2.82,-1.74,5.63,-3.48,8.48,-5.22c1.41,-0.88,2.84,-1.76,4.27,-2.66c-0.85,-2.41,-13.12,-28.28,-13.6,-28.58z"
                        android:fillColor="#00000000"
                        android:strokeColor="#4B7C5A"
                        android:strokeAlpha="0"
                        android:strokeWidth="4"/>

                    <!-- Bottom left triangle -->
                    <path
                        android:name="bottom_left"
                        android:pathData="M12.68,98.95c1.65,-2.79,4.18,-3.57,6.81,-2.12c2.57,1.45,5.1,2.93,7.51,4.66c2.44,1.76,3.36,4.34,2.16,7.52c-1.08,2.86,-2.41,5.58,-3.71,8.33c-0.82,1.73,-1.68,3.39,-2.63,5.01c-1.39,2.37,-3.42,3.64,-5.86,3.85c-1.81,0.18,-3.58,0.21,-5.83,0.32c-1.58,-0.11,-3.65,-0.18,-5.64,-0.46c-1.36,-0.21,-2.6,-0.92,-3.04,-2.58c-0.19,-0.78,-0.16,-1.66,-0.03,-2.47c0.29,-1.91,1.21,-3.53,2,-5.22c1.62,-3.5,3.27,-6.99,4.94,-10.45c1.05,-2.15,2.09,-4.34,3.33,-6.39z"
                        android:fillColor="#00000000"
                        android:strokeColor="#4B7C5A"
                        android:strokeAlpha="0"
                        android:strokeWidth="4"/>

                    <!-- Bottom right triangle -->
                    <path
                        android:name="bottom_right"
                        android:pathData="M101.22,96.52c2.4,-0.92,4.32,-0.28,5.83,2.05c1.1,1.69,2.02,3.56,2.9,5.4c1.23,2.47,2.4,4.98,3.56,7.52c1.26,2.72,2.52,5.47,3.72,8.26c0.28,0.67,0.41,1.52,0.44,2.26c0.13,1.98,-0.94,3.49,-2.77,3.92c-1.04,0.25,-2.14,0.35,-3.21,0.42c-1.1,0.07,-2.24,0.04,-3.34,0.04v0.14c-1.96,-0.14,-3.94,-0.21,-5.87,-0.46c-2.59,-0.28,-4.51,-1.91,-5.77,-4.41c-1.99,-3.81,-3.82,-7.73,-5.61,-11.65c-0.44,-0.99,-0.66,-2.15,-0.76,-3.25c-0.22,-2.43,0.92,-4.13,2.59,-5.33c1.7,-1.23,3.47,-2.33,5.24,-3.42c0.98,-0.57,1.99,-1.09,3.06,-1.48z"
                        android:fillColor="#00000000"
                        android:strokeColor="#4B7C5A"
                        android:strokeAlpha="0"
                        android:strokeWidth="4"/>
                </group>
            </group>
        </vector>
    </aapt:attr>

    <!-- Scale animation for the whole logo -->
    <target android:name="wrapper">
        <aapt:attr name="android:animation">
            <set>
                <objectAnimator
                    android:propertyName="scaleX"
                    android:duration="1000"
                    android:valueFrom="0.6"
                    android:valueTo="1.0"
                    android:valueType="floatType"
                    android:interpolator="@android:interpolator/overshoot"/>
                <objectAnimator
                    android:propertyName="scaleY"
                    android:duration="1000"
                    android:valueFrom="0.6"
                    android:valueTo="1.0"
                    android:valueType="floatType"
                    android:interpolator="@android:interpolator/overshoot"/>
            </set>
        </aapt:attr>
    </target>

    <!-- Main outer triangle stroke animation -->
    <target android:name="main_outer">
        <aapt:attr name="android:animation">
            <objectAnimator
                android:propertyName="strokeAlpha"
                android:duration="600"
                android:valueFrom="0"
                android:valueTo="1"
                android:valueType="floatType"
                android:interpolator="@android:interpolator/fast_out_slow_in"/>
        </aapt:attr>
    </target>

    <!-- Main inner triangle stroke animation -->
    <target android:name="main_inner">
        <aapt:attr name="android:animation">
            <objectAnimator
                android:propertyName="strokeAlpha"
                android:startOffset="100"
                android:duration="600"
                android:valueFrom="0"
                android:valueTo="1"
                android:valueType="floatType"
                android:interpolator="@android:interpolator/fast_out_slow_in"/>
        </aapt:attr>
    </target>

    <!-- Bottom left triangle stroke animation with delay -->
    <target android:name="bottom_left">
        <aapt:attr name="android:animation">
            <objectAnimator
                android:propertyName="strokeAlpha"
                android:startOffset="200"
                android:duration="600"
                android:valueFrom="0"
                android:valueTo="1"
                android:valueType="floatType"
                android:interpolator="@android:interpolator/fast_out_slow_in"/>
        </aapt:attr>
    </target>

    <!-- Bottom right triangle stroke animation with delay -->
    <target android:name="bottom_right">
        <aapt:attr name="android:animation">
            <objectAnimator
                android:propertyName="strokeAlpha"
                android:startOffset="400"
                android:duration="600"
                android:valueFrom="0"
                android:valueTo="1"
                android:valueType="floatType"
                android:interpolator="@android:interpolator/fast_out_slow_in"/>
        </aapt:attr>
    </target>
</animated-vector>
