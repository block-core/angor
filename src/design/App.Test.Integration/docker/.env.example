# Optional overrides for the local Angor test-signet stack.
# Copy to `.env` in the same folder and edit. Every value has a sensible
# default baked into docker-compose.yml, so `.env` is only needed if you
# hit a port clash or want a different chain identity.

# -- Ports (host side) ---------------------------------------------------
NODE_RPC_PORT=48332
NODE_P2P_PORT=48333
FULCRUM_PORT=48001
MEMPOOL_API_PORT=48999
MEMPOOL_WEB_PORT=48080
RELAY1_PORT=47777
RELAY2_PORT=47778
FAUCET_PORT=48500

# -- Signet node ---------------------------------------------------------
# Seconds between blocks produced by the built-in miner.
BLOCKPRODUCTIONDELAY=30

# Difficulty target (nBits). 1e0377ae ≈ very low, suitable for local mining.
NBITS=1e0377ae

# Advertised IP. Stay on loopback for purely local use.
EXTERNAL_IP=127.0.0.1

# Bitcoin Core RPC credentials (also used by faucet-api and mempool backend).
RPCUSER=rpcuser
RPCPASSWORD=rpcpassword

# Unique signet challenge / signing key for this local stack.
#
# These defaults were generated by `gen-signet-keys.sh` inside the custom
# signet image. Chain identity is deterministic but different from the
# public Angor signet. Do not reuse these values on a public network.
#
# To regenerate, clone block-core/bitcoin-custom-signet and run
#   ./gen-signet-keys.sh
# then paste SIGNETCHALLENGE and PRIVKEY here.
SIGNETCHALLENGE=5121036cb519d70c45e501ae30d3355ac431ac9496e83280108e495da9d691fe43515651ae
PRIVKEY=cQnkRJCDLZ3pFqjvmgV6TFVu8sbv6nyCwpfzsVerKJuNthfV3uup

# -- Faucet wallet -------------------------------------------------------
# BIP39 mnemonic used by both the faucet API and the miner reward address.
# Keep in sync with MINETO below.
FAUCET_MNEMONIC=margin radio diamond leg loud street announce guitar video shiver speed eyebrow

# BIP84 m/84'/1'/0'/0/0 address of FAUCET_MNEMONIC — coinbase rewards go here.
MINETO=tb1qk4pq0rh75qtph47wlufhyss43flhvhvwe4zt8a
